@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Xác thực đổi mật khẩu - BookWorm</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-slate-100 min-h-screen flex items-center justify-center font-montserrat">
    <div class="login-container">
        <!-- Left Side: OTP Form -->
        <div class="login-left-section">
            <div class="otp-left-logo">
                <img src="~/images/logo.svg" class="w-full h-full object-contain" alt="Logo" />
            </div>

            <h1 class="otp-title" style="font-size: 24px;">Xác thực tài khoản</h1>
            <p class="otp-desc">Nhập mã OTP gửi tới email của bạn để đổi mật khẩu lần đầu.</p>

            @if (ViewBag.Error != null)
            {
                <p class="text-red-500 text-sm text-center mb-4">@ViewBag.Error</p>
            }

            <form asp-action="VerifyOTPChangePassword" method="post">
                <input type="text" name="otp" placeholder="Nhập mã OTP" class="input-frame otp-input-frame" required autofocus>
                <button type="submit" class="btn-verify">XÁC THỰC</button>
            </form>
        </div>

        <!-- Right Side: Black Section -->
        <div class="login-black-section">
            <div class="right-logo-container">
                <img src="~/images/logo2.svg" class="w-full h-full object-contain" alt="LibraryPro Logo" />
            </div>
            
            <p class="right-text">
                "Hệ thống yêu cầu đổi mật khẩu cho lần đầu đăng nhập để đảm bảo an toàn tài khoản."
            </p>
        </div>
    </div>
</body>
</html>
