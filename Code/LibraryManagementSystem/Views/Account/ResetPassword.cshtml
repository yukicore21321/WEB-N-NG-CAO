@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đặt lại mật khẩu - LibraryPro</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-slate-100 min-h-screen flex items-center justify-center font-montserrat">
    <div class="login-container">
        <!-- Left Side: Black Section -->
        <div class="forgot-black-section">
            <div class="forgot-left-logo">
                <img src="~/images/logo2.svg" class="w-full h-full object-contain" alt="LibraryPro Logo" />
            </div>
            
            <p class="forgot-left-text">
                "Your premier digital library for borrowing and reading books"
            </p>
        </div>

        <!-- Right Side: Reset Password Form -->
        <div class="forgot-right-section">
            <a asp-action="Login" class="btn-back-right">BACK</a>

            <div class="forgot-right-logo">
                <img src="~/images/logo3.svg" class="w-full h-full object-contain" alt="Logo" />
            </div>

            <h1 class="reset-title">Reset Password</h1>
            <p class="reset-desc">Please enter your new password</p>

            <form asp-action="ResetPassword" method="post">
                <input type="password" name="newPassword" placeholder="New Password" class="input-frame reset-input-new" required>
                <input type="password" name="confirmPassword" placeholder="Confirm Password" class="input-frame reset-input-confirm" required>
                
                <button type="submit" class="btn-reset-confirm">RESET PASSWORD</button>
            </form>
        </div>
    </div>
</body>
</html>
