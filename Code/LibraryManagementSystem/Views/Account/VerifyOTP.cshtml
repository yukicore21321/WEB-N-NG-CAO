@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Xác thực OTP - LibraryPro</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-slate-100 min-h-screen flex items-center justify-center font-montserrat">
    <div class="login-container">
        <!-- Left Side: OTP Form -->
        <div class="login-left-section">
            <div class="otp-left-logo">
                <img src="~/images/logo.svg" class="w-full h-full object-contain" alt="Logo" />
            </div>

            <h1 class="otp-title">Check your Mailbox</h1>
            <p class="otp-desc">Please enter the OTP to proceed</p>

            <form asp-action="VerifyOTP" method="post">
                <input type="text" name="otp" placeholder="OTP" class="input-frame otp-input-frame" required>
                <button type="submit" class="btn-verify">VERIFY</button>
            </form>
        </div>

        <!-- Right Side: Black Section -->
        <div class="login-black-section">
            <div class="right-logo-container">
                <img src="~/images/logo2.svg" class="w-full h-full object-contain" alt="LibraryPro Logo" />
            </div>
            
            <p class="right-text">
                "Your premier digital library for borrowing and reading books"
            </p>
        </div>
    </div>
</body>
</html>
