@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đổi mật khẩu lần đầu - BookWorm</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-slate-100 min-h-screen flex items-center justify-center font-montserrat">
    <div class="login-container">
        <!-- Left Side: Form -->
        <div class="login-left-section">
            <div class="otp-left-logo" style="top: 30px;">
                <img src="~/images/logo.svg" class="w-full h-full object-contain" alt="Logo" />
            </div>

            <h1 class="otp-title" style="top: 150px; font-size: 28px;">Đổi mật khẩu</h1>
            <p class="otp-desc" style="top: 190px;">Vui lòng thiết lập mật khẩu mới cho tài khoản của bạn.</p>

            @if (ViewBag.Error != null)
            {
                <p class="text-red-500 text-sm text-center mb-4" style="position: absolute; width: 100%; top: 220px;">@ViewBag.Error</p>
            }

            <form asp-action="ForceChangePassword" method="post" style="position: absolute; width: 332px; top: 260px; left: 50%; transform: translateX(-50%);">
                <div class="mb-4">
                    <input type="password" name="newPassword" placeholder="Mật khẩu mới" class="input-frame" style="position: relative; top: 0; left: 0; width: 100%;" required>
                </div>
                <div class="mb-6">
                    <input type="password" name="confirmPassword" placeholder="Xác nhận mật khẩu" class="input-frame" style="position: relative; top: 0; left: 0; width: 100%;" required>
                </div>
                <button type="submit" class="btn-verify" style="position: relative; top: 0; left: 0; width: 100%; height: 50px;">ĐỔI MẬT KHẨU</button>
            </form>
        </div>

        <!-- Right Side: Black Section -->
        <div class="login-black-section">
            <div class="right-logo-container">
                <img src="~/images/logo2.svg" class="w-full h-full object-contain" alt="LibraryPro Logo" />
            </div>
            
            <p class="right-text">
                "Bảo mật tài khoản là ưu tiên hàng đầu của chúng tôi."
            </p>
        </div>
    </div>
</body>
</html>
