@model IEnumerable<LibraryManagementSystem.Models.BorrowRecord>
@{
    Layout = "_UserLayout";
    ViewData["Title"] = "Borrowed Books";
}

<div style="position: relative; width: 100%; height: 100%; overflow: hidden;">
    <!-- Black Vertical Bar on the Right -->
    <div style="position: absolute; width: 93px; height: 100%; right: 0; top: 0; background: #000000; display: flex; flex-direction: column; align-items: center; padding-top: 150px; z-index: 10;">
        <div style="font-family: 'Montserrat'; font-style: normal; font-weight: 900; font-size: 24px; line-height: 150%; color: #FFFFFF; text-transform: uppercase; writing-mode: vertical-rl; letter-spacing: 1em;">
            BOOKWORM
        </div>
    </div>

    <!-- Navigation Tabs (Pills) -->
    <div style="display: flex; gap: 10px; position: absolute; left: 33px; top: 25px; z-index: 5;">
        <a asp-action="BorrowedBooks" style="display: flex; align-items: center; justify-content: center; width: 160px; height: 40px; background: #000000; border-radius: 8px; font-family: 'Montserrat'; font-weight: 600; font-size: 14px; color: #FFFFFF; text-decoration: none;">
            Borrowed Books
        </a>
        <a asp-action="ReturnedBooks" style="display: flex; align-items: center; justify-content: center; width: 160px; height: 40px; background: #E8E8E8; border-radius: 8px; font-family: 'Montserrat'; font-weight: 500; font-size: 14px; color: #000000; text-decoration: none;">
            Returned Books
        </a>
    </div>
        
    <!-- Search Bar -->
    <div style="position: absolute; width: 280px; height: 44px; right: 120px; top: 19px; background: #FFFFFF; border: 1px solid #E8E8E8; border-radius: 12px; display: flex; align-items: center; padding: 0 16px; gap: 12px; z-index: 5;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M11.5 21C16.7467 21 21 16.7467 21 11.5C21 6.25329 16.7467 2 11.5 2C6.25329 2 2 6.25329 2 11.5C2 16.7467 6.25329 21 11.5 21Z" stroke="#292D32" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M22 22L20 20" stroke="#292D32" stroke-width="1.5" stroke-opacity="0.4" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <input type="text" placeholder="Search by ID" style="width: 100%; border: none; outline: none; font-family: 'Montserrat'; font-size: 14px; color: #727374;" />
    </div>

    <!-- Table Container -->
    <div style="position: absolute; width: calc(100% - 130px); height: calc(100% - 100px); left: 20px; top: 85px; background: #FFFFFF; border-radius: 12px; box-shadow: 0px 4px 20px rgba(0, 0, 0, 0.05); overflow: hidden;">
        <table style="width: 100%; border-collapse: collapse; text-align: center;">
            <thead>
                <tr style="height: 82px; border-bottom: 2px solid #EEEEEE; background: #FDFDFD;">
                    <th style="font-family: 'Montserrat'; font-weight: 600; font-size: 14px; color: #000000;">ID</th>
                    <th style="font-family: 'Montserrat'; font-weight: 600; font-size: 14px; color: #000000;">User ID</th>
                    <th style="font-family: 'Montserrat'; font-weight: 600; font-size: 14px; color: #000000;">Amount</th>
                    <th style="font-family: 'Montserrat'; font-weight: 600; font-size: 14px; color: #000000;">Due Date</th>
                    <th style="font-family: 'Montserrat'; font-weight: 600; font-size: 14px; color: #000000;">Date & Time</th>
                    <th style="font-family: 'Montserrat'; font-weight: 600; font-size: 14px; color: #000000;">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var record in Model)
                {
                    <tr style="height: 68px; border-bottom: 1px solid #EEEEEE; transition: background 0.2s;" onmouseover="this.style.background='#F9F9F9'" onmouseout="this.style.background='white'">
                        <td style="font-family: 'Montserrat'; font-size: 14px; color: #151619;">@record.Id</td>
                        <td style="font-family: 'Montserrat'; font-size: 14px; color: #151619;">@record.UserId</td>
                        <td style="font-family: 'Montserrat'; font-size: 14px; color: #151619;">001 Books</td>
                        <td style="font-family: 'Montserrat'; font-size: 14px; color: #151619;">@record.DueDate.ToString("dd - MM - yyyy")</td>
                        <td style="font-family: 'Montserrat'; font-size: 14px; color: #151619;">@record.BorrowDate.ToString("dd-MM-yyyy HH:mm:ss")</td>
                        <td style="display: flex; align-items: center; justify-content: center; height: 68px;">
                            <button style="display: flex; align-items: center; gap: 8px; background: #000000; color: #FFFFFF; border: none; padding: 8px 16px; border-radius: 8px; cursor: pointer; font-family: 'Montserrat'; font-weight: 600; font-size: 12px; transition: opacity 0.3s;" onmouseover="this.style.opacity='0.8'" onmouseout="this.style.opacity='1'" onclick="toggleReturnPopup(true)">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M17 16L21 12M21 12L17 8M21 12H9M13 16V17C13 18.6569 11.6569 20 10 20H5C3.34315 20 2 18.6569 2 17V7C2 5.34315 3.34315 4 5 4H10C11.6569 4 13 5.34315 13 7V8" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
                                Return
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Return Confirmation PopUp (Dùng cho trang Borrowed Books) -->
    <div id="returnPopup" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0, 0, 0, 0.5); z-index: 1000; align-items: center; justify-content: center;">
        <div style="position: relative; width: 1140px; height: 750px; background: #FFFFFF; border-radius: 20px; box-shadow: 0px 10px 30px rgba(0, 0, 0, 0.2); padding: 25px;">
            <div style="font-family: 'Montserrat'; font-weight: 700; font-size: 20px; margin-bottom: 20px;">Confirm Return</div>
            <!-- Frame 241 (Main List) -->
            <div style="box-sizing: border-box; width: 1087px; height: 500px; background: #FFFFFF; border: 1px solid #E8E8E8; border-radius: 12px; position: relative; overflow: hidden;">
                <!-- Header -->
                <div style="display: flex; align-items: center; height: 58px; border-bottom: 1px solid #E8E8E8; background: #FDFDFD; padding: 0 24px;">
                    <div style="width: 250px; font-family: 'Montserrat'; font-weight: 500; font-size: 16px; color: #151619;">Book ID</div>
                    <div style="width: 300px; font-family: 'Montserrat'; font-weight: 500; font-size: 16px; color: #151619;">Name</div>
                    <div style="width: 250px; font-family: 'Montserrat'; font-weight: 500; font-size: 16px; color: #151619;">Type</div>
                    <div style="width: 200px; font-family: 'Montserrat'; font-weight: 500; font-size: 16px; color: #151619;">Language</div>
                </div>
                <div style="height: calc(100% - 58px); overflow-y: auto;">
                    @for (int i = 0; i < 5; i++) {
                        <div style="display: flex; align-items: center; height: 68px; border-bottom: 1px solid #F5F5F5; padding: 0 24px;">
                            <div style="width: 250px; font-family: 'Montserrat'; font-size: 16px;">1</div>
                            <div style="width: 300px; font-family: 'Montserrat'; font-size: 16px;">Hibernate - Core</div>
                            <div style="width: 250px; font-family: 'Montserrat'; font-size: 16px;">Educational</div>
                            <div style="width: 200px; font-family: 'Montserrat'; font-size: 16px;">English</div>
                        </div>
                    }
                </div>
            </div>
            <!-- Summary -->
            <div style="box-sizing: border-box; position: absolute; width: 408px; height: 115px; left: 26px; top: 600px; border: 1px solid #E8E8E8; border-radius: 12px; display: flex; align-items: center;">
                <div style="width: 100px; height: 100%; display: flex; flex-direction: column; align-items: center; justify-content: center; position: relative;">
                    <div style="font-family: 'Montserrat'; font-weight: 600; font-size: 25px;">ID</div>
                    <div style="font-family: 'Montserrat'; font-weight: 400; font-size: 30px;">4</div>
                    <div style="position: absolute; right: 0; width: 2px; height: 80px; background: #000000;"></div>
                </div>
                <div style="flex: 1; padding-left: 20px;">
                    <div><span style="font-family: 'Montserrat'; font-weight: 600; font-size: 19px;">Total Books :</span> <span style="font-size: 20px;">04 Books</span></div>
                    <div><span style="font-family: 'Montserrat'; font-weight: 600; font-size: 19px;">Due Date :</span> <span style="font-size: 20px;">13 - 12 - 2024</span></div>
                </div>
            </div>
            <button onclick="toggleReturnPopup(false)" style="position: absolute; width: 259px; height: 54px; left: 538px; top: 628px; background: #D7D7D7; border-radius: 10px; border: none; font-weight: 700; cursor: pointer;">CANCEL</button>
            <button style="position: absolute; width: 259px; height: 54px; left: 825px; top: 628px; background: #000000; border-radius: 10px; border: none; font-weight: 700; color: #FFFFFF; cursor: pointer;">RETURN</button>
        </div>
    </div>

    <!-- Returned Books Detail PopUp (Dùng để xem lại lịch sử) -->
    <div id="historyPopup" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0, 0, 0, 0.5); z-index: 1000; align-items: center; justify-content: center;">
        <div style="position: relative; width: 1140px; height: 750px; background: #FFFFFF; border-radius: 20px; box-shadow: 0px 10px 30px rgba(0, 0, 0, 0.2); padding: 25px;">
            <div style="font-family: 'Montserrat'; font-weight: 700; font-size: 20px; margin-bottom: 20px;">Returned Books Detail</div>
            <!-- Frame 92 (Main List) -->
            <div style="box-sizing: border-box; width: 1087px; height: 558px; background: #FFFFFF; border: 1px solid #E8E8E8; border-radius: 12px; position: relative; overflow: hidden;">
                <div style="display: flex; align-items: center; height: 58px; border-bottom: 1px solid #E8E8E8; background: #FDFDFD; padding: 0 24px;">
                    <div style="width: 250px; font-family: 'Montserrat'; font-weight: 500; font-size: 16px;">Book ID</div>
                    <div style="width: 300px; font-family: 'Montserrat'; font-weight: 500; font-size: 16px;">Name</div>
                    <div style="width: 250px; font-family: 'Montserrat'; font-weight: 500; font-size: 16px;">Type</div>
                    <div style="width: 200px; font-family: 'Montserrat'; font-weight: 500; font-size: 16px;">Language</div>
                </div>
                <div style="height: calc(100% - 58px); overflow-y: auto;">
                    @for (int i = 0; i < 8; i++) {
                        <div style="display: flex; align-items: center; height: 68px; border-bottom: 1px solid #F5F5F5; padding: 0 24px;">
                            <div style="width: 250px; font-family: 'Montserrat'; font-size: 16px;">1</div>
                            <div style="width: 300px; font-family: 'Montserrat'; font-size: 16px;">Hibernate - Core</div>
                            <div style="width: 250px; font-family: 'Montserrat'; font-size: 16px;">Educational</div>
                            <div style="width: 200px; font-family: 'Montserrat'; font-size: 16px;">English</div>
                        </div>
                    }
                </div>
            </div>
            <!-- Summary (Frame 240) -->
            <div style="box-sizing: border-box; position: absolute; width: 408px; height: 115px; left: 26px; top: 600px; border: 1px solid #E8E8E8; border-radius: 12px; display: flex; align-items: center;">
                <div style="width: 100px; height: 100%; display: flex; flex-direction: column; align-items: center; justify-content: center; position: relative;">
                    <div style="font-family: 'Montserrat'; font-weight: 600; font-size: 25px;">ID</div>
                    <div style="font-family: 'Montserrat'; font-weight: 400; font-size: 30px;">4</div>
                    <div style="position: absolute; right: 0; width: 2px; height: 80px; background: #000000;"></div>
                </div>
                <div style="flex: 1; padding-left: 20px;">
                    <div><span style="font-family: 'Montserrat'; font-weight: 600; font-size: 19px;">Total Books :</span> <span style="font-size: 20px;">04 Books</span></div>
                    <div><span style="font-family: 'Montserrat'; font-weight: 600; font-size: 19px;">Due Date :</span> <span style="font-size: 20px;">13 - 12 - 2024</span></div>
                </div>
            </div>
            <!-- btn Close PopUp -->
            <button onclick="toggleHistoryPopup(false)" style="position: absolute; width: 259px; height: 54px; left: 824px; top: 636px; background: #000000; border-radius: 10px; border: none; font-family: 'Montserrat'; font-weight: 700; font-size: 16px; color: #FFFFFF; cursor: pointer; transition: opacity 0.3s;" onmouseover="this.style.opacity='0.8'" onmouseout="this.style.opacity='1'">CLOSE</button>
        </div>
    </div>

    <script>
        function toggleReturnPopup(show) {
            document.getElementById('returnPopup').style.display = show ? 'flex' : 'none';
        }
        function toggleHistoryPopup(show) {
            document.getElementById('historyPopup').style.display = show ? 'flex' : 'none';
        }
    </script>
</div>
