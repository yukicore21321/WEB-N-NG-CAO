@{
    Layout = "_AdminLayout";
}

<div class="space-y-8 animate-fade-in">
    <!-- Stats Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="premium-card p-6 flex items-center space-x-4">
            <div class="w-14 h-14 bg-blue-50 rounded-2xl flex items-center justify-center text-blue-600">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                </svg>
            </div>
            <div>
                <p class="text-sm font-medium text-slate-500">Tổng số sách</p>
                <h3 class="text-2xl font-bold text-slate-800">1,284</h3>
            </div>
        </div>

        <div class="premium-card p-6 flex items-center space-x-4">
            <div class="w-14 h-14 bg-indigo-50 rounded-2xl flex items-center justify-center text-indigo-600">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
                </svg>
            </div>
            <div>
                <p class="text-sm font-medium text-slate-500">Sách đang mượn</p>
                <h3 class="text-2xl font-bold text-slate-800">156</h3>
            </div>
        </div>

        <div class="premium-card p-6 flex items-center space-x-4">
            <div class="w-14 h-14 bg-amber-50 rounded-2xl flex items-center justify-center text-amber-600">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
                </svg>
            </div>
            <div>
                <p class="text-sm font-medium text-slate-500">Người dùng</p>
                <h3 class="text-2xl font-bold text-slate-800">3,420</h3>
            </div>
        </div>

        <div class="premium-card p-6 flex items-center space-x-4">
            <div class="w-14 h-14 bg-emerald-50 rounded-2xl flex items-center justify-center text-emerald-600">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                </svg>
            </div>
            <div>
                <p class="text-sm font-medium text-slate-500">Lượt mượn mới</p>
                <h3 class="text-2xl font-bold text-slate-800">+42</h3>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Main Stats Chart (Mockup) -->
        <div class="lg:col-span-2 premium-card p-8">
            <div class="flex items-center justify-between mb-8">
                <div>
                    <h3 class="text-xl font-bold text-slate-800">Hoạt động mượn sách</h3>
                    <p class="text-sm text-slate-500">Thống kê theo tuần</p>
                </div>
                <select class="bg-slate-50 border-none rounded-lg text-sm px-3 py-1.5 outline-none focus:ring-2 focus:ring-primary/10">
                    <option>7 ngày qua</option>
                    <option>30 ngày qua</option>
                </select>
            </div>
            <div class="h-64 flex items-end justify-between space-x-2">
                <div class="flex-grow bg-slate-50 rounded-t-xl relative group">
                    <div class="absolute bottom-0 w-full bg-primary/20 group-hover:bg-primary/40 transition-all rounded-t-xl" style="height: 40%"></div>
                </div>
                <div class="flex-grow bg-slate-50 rounded-t-xl relative group">
                    <div class="absolute bottom-0 w-full bg-primary/20 group-hover:bg-primary/40 transition-all rounded-t-xl" style="height: 65%"></div>
                </div>
                <div class="flex-grow bg-slate-50 rounded-t-xl relative group">
                    <div class="absolute bottom-0 w-full bg-primary/20 group-hover:bg-primary/40 transition-all rounded-t-xl" style="height: 80%"></div>
                </div>
                <div class="flex-grow bg-slate-50 rounded-t-xl relative group">
                    <div class="absolute bottom-0 w-full bg-primary/40 transition-all rounded-t-xl" style="height: 95%"></div>
                </div>
                <div class="flex-grow bg-slate-50 rounded-t-xl relative group">
                    <div class="absolute bottom-0 w-full bg-primary/20 group-hover:bg-primary/40 transition-all rounded-t-xl" style="height: 55%"></div>
                </div>
                <div class="flex-grow bg-slate-50 rounded-t-xl relative group">
                    <div class="absolute bottom-0 w-full bg-primary/20 group-hover:bg-primary/40 transition-all rounded-t-xl" style="height: 70%"></div>
                </div>
                <div class="flex-grow bg-slate-50 rounded-t-xl relative group">
                    <div class="absolute bottom-0 w-full bg-primary/20 group-hover:bg-primary/40 transition-all rounded-t-xl" style="height: 45%"></div>
                </div>
            </div>
            <div class="flex justify-between mt-4 text-xs font-medium text-slate-400 px-2">
                <span>T2</span><span>T3</span><span>T4</span><span>T5</span><span>T6</span><span>T7</span><span>CN</span>
            </div>
        </div>

        <!-- Recent Activity -->
        <div class="premium-card p-8">
            <h3 class="text-xl font-bold text-slate-800 mb-6">Giao dịch gần đây</h3>
            <div class="space-y-6">
                <div class="flex items-start space-x-4">
                    <div class="w-2 h-2 mt-2 rounded-full bg-primary"></div>
                    <div>
                        <p class="text-sm font-semibold text-slate-800">Nguyễn Văn A</p>
                        <p class="text-xs text-slate-500">Mượn: "Lập trình C# cơ bản"</p>
                        <p class="text-[10px] text-slate-400 mt-1">2 phút trước</p>
                    </div>
                </div>
                <div class="flex items-start space-x-4">
                    <div class="w-2 h-2 mt-2 rounded-full bg-emerald-500"></div>
                    <div>
                        <p class="text-sm font-semibold text-slate-800">Trần Thị B</p>
                        <p class="text-xs text-slate-500">Trả: "Thiết kế Web hiện đại"</p>
                        <p class="text-[10px] text-slate-400 mt-1">15 phút trước</p>
                    </div>
                </div>
                <div class="flex items-start space-x-4">
                    <div class="w-2 h-2 mt-2 rounded-full bg-primary"></div>
                    <div>
                        <p class="text-sm font-semibold text-slate-800">Lê Văn C</p>
                        <p class="text-xs text-slate-500">Mượn: "Trí tuệ nhân tạo"</p>
                        <p class="text-[10px] text-slate-400 mt-1">1 giờ trước</p>
                    </div>
                </div>
                <div class="flex items-start space-x-4">
                    <div class="w-2 h-2 mt-2 rounded-full bg-red-500"></div>
                    <div>
                        <p class="text-sm font-semibold text-slate-800">Phạm Văn D</p>
                        <p class="text-xs text-slate-500">Quá hạn: "Cơ sở dữ liệu SQL"</p>
                        <p class="text-[10px] text-slate-400 mt-1">3 giờ trước</p>
                    </div>
                </div>
            </div>
            <button class="w-full mt-8 py-3 bg-slate-50 text-slate-600 text-sm font-bold rounded-xl hover:bg-slate-100 transition-colors">
                Xem tất cả hoạt động
            </button>
        </div>
    </div>
</div>
