
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<style>
    .dashboard-container {
        padding: 24px;
    }
    .dashboard-title {
        font-size: 32px;
        font-weight: 700;
        margin-bottom: 24px;
    }
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin-bottom: 28px;
    }
    .stats-card {
        background: white;
        border-radius: 20px;
        padding: 24px;
        box-shadow: 0 4px 14px rgba(0,0,0,0.05);
        position: relative;
        overflow: hidden;
    }
    .stats-card::after {
        content: "";
        position: absolute;
        right: -20px;
        bottom: -20px;
        width: 90px;
        height: 90px;
        border-radius: 50%;
        background: rgba(0,0,0,0.04);
    }
    .stats-label {
        font-size: 15px;
        color: #777;
        margin-bottom: 12px;
    }
    .stats-value {
        font-size: 36px;
        font-weight: 700;
        color: black;
    }
    .stats-icon {
        width: 56px;
        height: 56px;
        border-radius: 16px;
        background: #F3F3F3;
        display: flex;
        align-items: center;
        justify-content: center;
        position: absolute;
        top: 24px;
        right: 24px;
    }
    .dashboard-row {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 20px;
        margin-bottom: 20px;
    }
    .dashboard-box {
        background: white;
        border-radius: 20px;
        padding: 24px;
        box-shadow: 0 4px 14px rgba(0,0,0,0.05);
    }
    .dashboard-box-title {
        font-size: 20px;
        font-weight: 700;
        margin-bottom: 20px;
    }
    .borrow-table {
        width: 100%;
        border-collapse: collapse;
    }
    .borrow-table th {
        background: #111;
        color: white;
        padding: 14px;
        font-size: 14px;
    }
    .borrow-table td {
        padding: 14px;
        border-bottom: 1px solid #ECECEC;
        font-size: 14px;
    }
    .status-borrowed {
        background: #FFF3CD;
        color: #856404;
        padding: 6px 12px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 600;
    }
    .status-returned {
        background: #D4EDDA;
        color: #155724;
        padding: 6px 12px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 600;
    }
    .status-overdue {
        background: #F8D7DA;
        color: #721C24;
        padding: 6px 12px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 600;
    }
    .book-item {
        display: flex;
        gap: 14px;
        align-items: center;
        padding-bottom: 16px;
        margin-bottom: 16px;
        border-bottom: 1px solid #ECECEC;
    }
    .book-item:last-child {
        margin-bottom: 0;
        border-bottom: none;
    }
    .book-item img {
        width: 60px;
        height: 80px;
        object-fit: cover;
        border-radius: 12px;
    }
    .book-title {
        font-size: 15px;
        font-weight: 700;
        margin-bottom: 6px;
    }
    .book-author {
        font-size: 13px;
        color: #777;
        margin-bottom: 6px;
    }
    .book-quantity {
        font-size: 13px;
        font-weight: 600;
        color: #0F9D58;
    }
    .quick-stats {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
    }
    .quick-box {
        background: white;
        border-radius: 20px;
        padding: 24px;
        box-shadow: 0 4px 14px rgba(0,0,0,0.05);
    }
    .quick-box h4 {
        font-size: 16px;
        margin-bottom: 12px;
    }
    .quick-box p {
        font-size: 28px;
        font-weight: 700;
        margin: 0;
    }
    @@media(max-width: 1200px) {
        .stats-grid {
            grid-template-columns: repeat(2, 1fr);
        }
        .dashboard-row {
            grid-template-columns: 1fr;
        }
    }
    @@media(max-width: 768px) {
        .stats-grid {
            grid-template-columns: 1fr;
        }
        .quick-stats {
            grid-template-columns: 1fr;
        }
    }
</style>
<div class="dashboard-container">
    <div class="dashboard-title">
        Dashboard thống kê thư viện
    </div>
    <!-- STATS -->
    <div class="stats-grid">
        <div class="stats-card">
            <div class="stats-icon">
                <img src="~/images/book-icon.png" width="28" />
            </div>
            <div class="stats-label">
                Tổng số sách
            </div>
            <div class="stats-value">
                @ViewBag.TotalBooks
            </div>
        </div>
        <div class="stats-card">
            <div class="stats-icon">
                <img src="~/images/category-icon.png" width="28" />
            </div>
            <div class="stats-label">
                Thể loại
            </div>
            <div class="stats-value">
                @ViewBag.TotalCategories
            </div>
        </div>
        <div class="stats-card">
            <div class="stats-icon">
                <img src="~/images/customer-icon.png" width="28" />
            </div>
            <div class="stats-label">
                Khách hàng
            </div>
            <div class="stats-value">
                @ViewBag.TotalCustomers
            </div>
        </div>
        <div class="stats-card">
            <div class="stats-icon">
                <img src="~/images/borrow-icon.png" width="28" />
            </div>
            <div class="stats-label">
                Phiếu đang mượn
            </div>
            <div class="stats-value">
                @ViewBag.TotalBorrowing
            </div>
        </div>
    </div>
    <!-- ROW -->
    <div class="dashboard-row">
        <!-- RECENT BORROW -->
        <div class="dashboard-box">
            <div class="dashboard-box-title">
                Phiếu mượn gần đây
            </div>
            <table class="borrow-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Khách hàng</th>
                        <th>Ngày mượn</th>
                        <th>Hạn trả</th>
                        <th>Trạng thái</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in ViewBag.RecentTickets)
                    {
                        <tr>
                            <td>#@item.Id</td>
                            <td>
                                @item.Customer.FullName
                            </td>
                            <td>
                                @item.BorrowDate.ToString("dd/MM/yyyy")
                            </td>
                            <td>
                                @item.DueDate.ToString("dd/MM/yyyy")
                            </td>
                            <td>
                                @if (item.Status == "Returned")
                                {
                                    <span class="status-returned">
                                        Returned
                                    </span>
                                }
                                else if (
                                    item.DueDate.Date < DateTime.Now.Date
                                )
                                {
                                    <span class="status-overdue">
                                        Overdue
                                    </span>
                                }
                                else
                                {
                                    <span class="status-borrowed">
                                        Borrowed
                                    </span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <!-- TOP BOOKS -->
        <div class="dashboard-box">
            <div class="dashboard-box-title">
                Sách mới thêm
            </div>
            @foreach (var book in ViewBag.LatestBooks)
            {
                <div class="book-item">
                    <img src="@book.ImageUrl" />
                    <div>
                        <div class="book-title">
                            @book.Title
                        </div>
                        <div class="book-author">
                            @book.Author
                        </div>
                        <div class="book-quantity">
                            Còn @book.AvailableQuantity quyển
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
    <!-- QUICK -->
    <div class="quick-stats">
        <div class="quick-box">
            <h4>Sách đã được mượn</h4>
            <p>@ViewBag.TotalBorrowedBooks</p>
        </div>
        <div class="quick-box">
            <h4>Phiếu quá hạn</h4>
            <p>@ViewBag.TotalOverdue</p>
        </div>
    </div>
</div>




