@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Forgot Password - Admin</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            margin: 0;
            padding: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100vh;
            background-color: #F5F5F5;
            font-family: 'Montserrat', sans-serif;
        }

        .container {
            position: relative;
            width: 930px;
            height: 575px;
            background: #FFFFFF;
            box-shadow: 0px 10px 40px rgba(0, 0, 0, 0.1);
            overflow: hidden;
            display: flex;
        }

        /* Left Side - Black Decoration */
        .decor-side {
            position: absolute;
            width: 469px;
            height: 575px;
            left: 0px;
            top: 0px;
            background: #000000;
            border-radius: 0px 40px 40px 0px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            color: #FFFFFF;
            padding: 40px;
            box-sizing: border-box;
        }

        .slogan {
            position: absolute;
            left: 20.68%;
            right: 20.47%;
            top: 62.96%;
            font-weight: 400;
            font-size: 19px;
            line-height: 140%;
            text-align: center;
            color: #FFFFFF;
        }

        /* Right Side - Form */
        .form-side {
            flex: 1;
            margin-left: 469px;
            position: relative;
            padding: 40px;
        }

        .title {
            position: absolute;
            width: 257px;
            height: 42px;
            left: 109px;
            top: 207px;
            font-weight: 500;
            font-size: 30px;
            line-height: 140%;
            color: #000000;
        }

        .instruction {
            position: absolute;
            width: 169px;
            height: 17px;
            left: 153px;
            top: 266px;
            font-weight: 400;
            font-size: 12px;
            line-height: 140%;
            color: #000000;
        }

        .input-frame {
            box-sizing: border-box;
            display: flex;
            flex-direction: row;
            align-items: center;
            padding: 12px 16px;
            gap: 8px;
            position: absolute;
            width: 267px;
            height: 42px;
            left: 104px;
            top: 328px;
            background: #FFFFFF;
            border: 1px solid #3D3E3E;
            border-radius: 12px;
        }

        .input-frame input {
            border: none;
            outline: none;
            width: 100%;
            font-family: 'Montserrat';
            font-size: 13px;
            color: #151619;
        }

        .btn-reset {
            position: absolute;
            width: 267px;
            height: 42px;
            left: 104px;
            top: 391px;
            background: #000000;
            border-radius: 15px;
            border: none;
            color: #FFFFFF;
            font-family: 'Montserrat';
            font-weight: 700;
            font-size: 13px;
            cursor: pointer;
            transition: opacity 0.3s;
        }

        .btn-reset:hover {
            opacity: 0.8;
        }

        /* Back Button */
        .btn-back {
            box-sizing: border-box;
            position: absolute;
            width: 53px;
            height: 22px;
            left: 410px;
            top: 12px;
            background: #FFFFFF;
            border: 1px solid #000000;
            border-radius: 20px 0px 0px 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            text-decoration: none;
            font-weight: 700;
            font-size: 9px;
            color: #000000;
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- Left Side - Black -->
        <div class="decor-side">
            <img src="/images/logo.svg" alt="Logo" style="width: 120px; height: auto; filter: brightness(0) invert(1); margin-top: -100px;">
            <div class="slogan">"Your premier digital library for borrowing and reading books"</div>
        </div>

        <!-- Right Side - White -->
        <div class="form-side">
            <a href="/Admin/Login" class="btn-back">BACK</a>
            
            <div class="title">Forgot Password</div>
            <div class="instruction">Please enter your username</div>
            
            <form action="/Admin/ResetPassword" method="POST">
                <div class="input-frame">
                    <input type="text" name="username" placeholder="Username" required>
                </div>
                <button type="submit" class="btn-reset">RESET PASSWORD</button>
            </form>
        </div>
    </div>
</body>
</html>
