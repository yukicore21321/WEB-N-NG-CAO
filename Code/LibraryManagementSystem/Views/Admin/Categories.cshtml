@{
    ViewData["Title"] = "Category Management";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .admin-page-container {
        position: absolute;
        left: 20px;
        top: 170px;
        width: calc(100% - 40px);
        height: calc(100vh - 210px);
        background: #FFFFFF;
        border-radius: 12px;
        padding: 30px;
        box-sizing: border-box;
        box-shadow: 0px 4px 10px rgba(0, 0, 0, 0.05);
        overflow: hidden;
    }

    /* Tabs Container */
    .tabs-container {
        position: absolute;
        left: 20px;
        top: 102px;
        display: flex;
        gap: 0;
    }

    .tab-btn {
        width: 244px;
        height: 38px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'Montserrat';
        font-weight: 600;
        font-size: 16px;
        text-decoration: none;
        cursor: pointer;
        border: none;
    }

    .tab-borrowed {
        background: #E3E3E3;
        color: #000000;
        border-radius: 12px 0 0 12px;
    }

    .tab-overdue {
        background: #E3E3E3;
        color: #000000;
        border-radius: 0 0 0 0;
    }

    .tab-categories {
        background: #000000;
        color: #FFFFFF;
        border-radius: 0 12px 12px 0;
    }

    .btn-add {
        background: #000000;
        color: #FFFFFF;
        padding: 12px 24px;
        border-radius: 12px;
        font-weight: 600;
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 10px;
        transition: opacity 0.3s;
    }

    .admin-table {
        width: 100%;
        border-collapse: collapse;
    }

    .admin-table th {
        text-align: left;
        padding: 15px 20px;
        background: #F9F9F9;
        font-weight: 600;
        font-size: 14px;
        color: #151619;
        border-bottom: 1px solid #E8E8E8;
    }

    .admin-table td {
        padding: 15px 20px;
        border-bottom: 1px solid #F5F5F5;
        font-size: 14px;
        color: #333;
    }
</style>

<div class="tabs-container">
    <a href="/Admin/BorrowRecords" class="tab-btn tab-borrowed">Borrowed Books</a>
    <a href="#" class="tab-btn tab-overdue">Overdue Borrowers</a>
    <a href="/Admin/Categories" class="tab-btn tab-categories">Book Categories</a>
</div>

<div class="admin-page-container">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
        <h2 style="margin: 0; font-weight: 700; font-size: 24px;">Book Categories</h2>
        <a href="#" class="btn-add">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 5V19M5 12H19" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Add New Category
        </a>
    </div>

    <div style="height: calc(100% - 80px); overflow-y: auto;">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Category Name</th>
                    <th>Books Count</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @{
                    string[] categories = { "Technology", "Science", "Education", "Literature", "History", "Art" };
                    for (int i = 0; i < categories.Length; i++)
                    {
                        <tr>
                            <td>#CAT-@((i + 1).ToString("D2"))</td>
                            <td style="font-weight: 600;">@categories[i]</td>
                            <td>@(25 + i * 5) Books</td>
                            <td>
                                <div style="display: flex; gap: 15px;">
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" style="cursor:pointer;">
                                        <path d="M11 4H4C3.46957 4 2.96086 4.21071 2.58579 4.58579C2.21071 4.96086 2 5.46957 2 6V20C2 20.5304 2.21071 21.0391 2.58579 21.4142C2.96086 21.7893 3.46957 22 4 22H18C18.5304 22 19.0391 21.7893 19.4142 21.4142C19.7893 21.0391 20 20.5304 20 20V13M18.5 2.5C18.8978 2.10217 19.4374 1.87868 20 1.87868C20.5626 1.87868 21.1022 2.10217 21.5 2.5C21.8978 2.89783 22.1213 3.43739 22.1213 4C22.1213 4.56261 21.8978 5.10217 21.5 5.5L12 15L8 16L9 12L18.5 2.5Z" stroke="#4F46E5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                    </svg>
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" style="cursor:pointer;">
                                        <path d="M3 6H21M19 6V20C19 21 18 22 17 22H7C6 22 5 21 5 20V6M8 6V4C8 3 9 2 10 2H14C15 2 16 3 16 4V6" stroke="#DC2626" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                    </svg>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
