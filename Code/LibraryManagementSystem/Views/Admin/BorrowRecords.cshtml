@{
    Layout = "_AdminLayout";
}

<div class="space-y-6 animate-fade-in">
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold text-slate-800">Quản lý Mượn / Trả</h1>
            <p class="text-slate-500">Theo dõi lịch sử và trạng thái mượn sách của người dùng.</p>
        </div>
        <button class="px-4 py-2 bg-primary text-white rounded-xl font-medium hover:bg-blue-700 transition-all flex items-center space-x-2 shadow-lg shadow-primary/20">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
            <span>Tạo phiếu mượn mới</span>
        </button>
    </div>

    <!-- Quick Stats -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="premium-card p-4 flex items-center space-x-4 border-l-4 border-l-blue-500">
            <div class="p-2 bg-blue-50 text-blue-500 rounded-lg">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
            </div>
            <div>
                <p class="text-xs font-medium text-slate-500">Đang mượn</p>
                <p class="text-lg font-bold text-slate-800">156</p>
            </div>
        </div>
        <div class="premium-card p-4 flex items-center space-x-4 border-l-4 border-l-red-500">
            <div class="p-2 bg-red-50 text-red-500 rounded-lg">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                </svg>
            </div>
            <div>
                <p class="text-xs font-medium text-slate-500">Quá hạn</p>
                <p class="text-lg font-bold text-slate-800">24</p>
            </div>
        </div>
        <div class="premium-card p-4 flex items-center space-x-4 border-l-4 border-l-emerald-500">
            <div class="p-2 bg-emerald-50 text-emerald-500 rounded-lg">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
            </div>
            <div>
                <p class="text-xs font-medium text-slate-500">Đã trả hôm nay</p>
                <p class="text-lg font-bold text-slate-800">12</p>
            </div>
        </div>
    </div>

    <!-- Table -->
    <div class="premium-card overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead class="bg-slate-50/50">
                    <tr>
                        <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-wider">Người mượn</th>
                        <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-wider">Sách</th>
                        <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-wider">Ngày mượn</th>
                        <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-wider">Hạn trả</th>
                        <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-wider">Trạng thái</th>
                        <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-wider text-right">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    <tr class="hover:bg-slate-50/80 transition-colors">
                        <td class="px-6 py-4">
                            <div class="flex items-center space-x-3">
                                <div class="w-8 h-8 rounded-full bg-slate-100 flex items-center justify-center text-xs font-bold text-slate-600">NV</div>
                                <div>
                                    <p class="text-sm font-bold text-slate-800">Nguyễn Văn A</p>
                                    <p class="text-[10px] text-slate-500">ID: USER-123</p>
                                </div>
                            </div>
                        </td>
                        <td class="px-6 py-4">
                            <p class="text-sm font-medium text-slate-800 line-clamp-1">Lập trình C# cơ bản</p>
                        </td>
                        <td class="px-6 py-4">
                            <p class="text-sm text-slate-600">01/05/2024</p>
                        </td>
                        <td class="px-6 py-4">
                            <p class="text-sm text-slate-600 font-medium">15/05/2024</p>
                        </td>
                        <td class="px-6 py-4">
                            <span class="px-3 py-1 bg-blue-50 text-blue-600 rounded-full text-[10px] font-bold">Đang mượn</span>
                        </td>
                        <td class="px-6 py-4 text-right">
                            <button class="px-3 py-1.5 bg-emerald-50 text-emerald-600 text-xs font-bold rounded-lg hover:bg-emerald-500 hover:text-white transition-all">
                                Nhận trả sách
                            </button>
                        </td>
                    </tr>
                    <tr class="hover:bg-slate-50/80 transition-colors">
                        <td class="px-6 py-4">
                            <div class="flex items-center space-x-3">
                                <div class="w-8 h-8 rounded-full bg-slate-100 flex items-center justify-center text-xs font-bold text-slate-600">TB</div>
                                <div>
                                    <p class="text-sm font-bold text-slate-800">Trần Thị B</p>
                                    <p class="text-[10px] text-slate-500">ID: USER-456</p>
                                </div>
                            </div>
                        </td>
                        <td class="px-6 py-4">
                            <p class="text-sm font-medium text-slate-800 line-clamp-1">Kinh tế vĩ mô 2024</p>
                        </td>
                        <td class="px-6 py-4">
                            <p class="text-sm text-slate-600">20/04/2024</p>
                        </td>
                        <td class="px-6 py-4">
                            <p class="text-sm text-red-500 font-bold">04/05/2024</p>
                        </td>
                        <td class="px-6 py-4">
                            <span class="px-3 py-1 bg-red-50 text-red-600 rounded-full text-[10px] font-bold">Quá hạn 2 ngày</span>
                        </td>
                        <td class="px-6 py-4 text-right">
                            <button class="px-3 py-1.5 bg-emerald-50 text-emerald-600 text-xs font-bold rounded-lg hover:bg-emerald-500 hover:text-white transition-all">
                                Nhận trả sách
                            </button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
