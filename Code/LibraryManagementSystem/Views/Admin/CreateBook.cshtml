@{
    Layout = "_AdminLayout";
}

<div class="max-w-4xl mx-auto space-y-8 animate-fade-in">
    <div class="flex items-center space-x-4">
        <a asp-controller="Admin" asp-action="Books" class="p-2 bg-white border border-slate-200 rounded-xl text-slate-400 hover:text-slate-600 transition-colors shadow-sm">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
        </a>
        <div>
            <h1 class="text-2xl font-bold text-slate-800">Thêm sách mới</h1>
            <p class="text-slate-500">Nhập đầy đủ thông tin để thêm tài liệu vào thư viện.</p>
        </div>
    </div>

    <form class="space-y-8">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <!-- Left Column: Image Upload -->
            <div class="md:col-span-1 space-y-4">
                <div class="premium-card p-6 text-center">
                    <p class="text-sm font-bold text-slate-700 mb-4">Ảnh bìa sách</p>
                    <div class="relative group cursor-pointer">
                        <div class="aspect-[3/4] bg-slate-50 border-2 border-dashed border-slate-200 rounded-2xl flex flex-col items-center justify-center transition-all group-hover:border-primary group-hover:bg-blue-50 overflow-hidden">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-slate-300 group-hover:text-primary mb-2 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                            </svg>
                            <span class="text-xs text-slate-400 font-medium group-hover:text-primary transition-colors">Tải lên hoặc kéo thả</span>
                        </div>
                        <input type="file" class="absolute inset-0 opacity-0 cursor-pointer">
                    </div>
                    <p class="text-[10px] text-slate-400 mt-4 leading-relaxed">Định dạng hỗ trợ: JPG, PNG. Tối đa 2MB.</p>
                </div>

                <div class="premium-card p-6">
                    <p class="text-sm font-bold text-slate-700 mb-4">File tài liệu số</p>
                    <div class="flex items-center space-x-3 p-3 bg-slate-50 rounded-xl border border-slate-100 hover:border-primary/30 transition-all cursor-pointer">
                        <div class="w-10 h-10 bg-red-50 text-red-500 rounded-lg flex items-center justify-center">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
                            </svg>
                        </div>
                        <div class="flex-grow">
                            <p class="text-xs font-bold text-slate-700">Tải lên file PDF</p>
                            <p class="text-[10px] text-slate-400">Dành cho sách điện tử</p>
                        </div>
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                        </svg>
                    </div>
                </div>
            </div>

            <!-- Right Column: Form Details -->
            <div class="md:col-span-2 space-y-6">
                <div class="premium-card p-8 space-y-6">
                    <h3 class="text-lg font-bold text-slate-800 pb-4 border-b border-slate-50">Thông tin cơ bản</h3>
                    
                    <div class="grid grid-cols-1 gap-6">
                        <div class="space-y-2">
                            <label class="text-sm font-bold text-slate-700">Tiêu đề sách <span class="text-red-500">*</span></label>
                            <input type="text" placeholder="Ví dụ: Lập trình ASP.NET Core MVC" class="w-full px-4 py-3 bg-slate-50 border border-slate-100 rounded-xl outline-none focus:ring-2 focus:ring-primary/10 transition-all">
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div class="space-y-2">
                                <label class="text-sm font-bold text-slate-700">Tác giả</label>
                                <input type="text" placeholder="Tên tác giả" class="w-full px-4 py-3 bg-slate-50 border border-slate-100 rounded-xl outline-none focus:ring-2 focus:ring-primary/10 transition-all">
                            </div>
                            <div class="space-y-2">
                                <label class="text-sm font-bold text-slate-700">Thể loại</label>
                                <select class="w-full px-4 py-3 bg-slate-50 border border-slate-100 rounded-xl outline-none focus:ring-2 focus:ring-primary/10 appearance-none">
                                    <option>-- Chọn thể loại --</option>
                                    <option>Công nghệ thông tin</option>
                                    <option>Kinh tế</option>
                                    <option>Văn học</option>
                                    <option>Ngoại ngữ</option>
                                </select>
                            </div>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                            <div class="space-y-2">
                                <label class="text-sm font-bold text-slate-700">ISBN</label>
                                <input type="text" placeholder="Mã ISBN" class="w-full px-4 py-3 bg-slate-50 border border-slate-100 rounded-xl outline-none focus:ring-2 focus:ring-primary/10 transition-all">
                            </div>
                            <div class="space-y-2">
                                <label class="text-sm font-bold text-slate-700">Tổng số bản</label>
                                <input type="number" value="1" min="1" class="w-full px-4 py-3 bg-slate-50 border border-slate-100 rounded-xl outline-none focus:ring-2 focus:ring-primary/10 transition-all">
                            </div>
                             <div class="space-y-2">
                                <label class="text-sm font-bold text-slate-700">Số bản hiện có</label>
                                <input type="number" value="1" min="0" class="w-full px-4 py-3 bg-slate-50 border border-slate-100 rounded-xl outline-none focus:ring-2 focus:ring-primary/10 transition-all">
                            </div>
                        </div>

                        <div class="space-y-2">
                            <label class="text-sm font-bold text-slate-700">Mô tả sách</label>
                            <textarea rows="5" placeholder="Tóm tắt nội dung sách..." class="w-full px-4 py-3 bg-slate-50 border border-slate-100 rounded-xl outline-none focus:ring-2 focus:ring-primary/10 transition-all resize-none"></textarea>
                        </div>
                    </div>
                </div>

                <div class="flex items-center justify-end space-x-4">
                    <button type="button" class="px-8 py-3 bg-white border border-slate-200 rounded-xl text-slate-600 font-bold hover:bg-slate-50 transition-colors shadow-sm">Hủy</button>
                    <button type="submit" class="px-8 py-3 bg-primary text-white rounded-xl font-bold hover:bg-blue-700 transition-all shadow-lg shadow-primary/20">Lưu thông tin</button>
                </div>
            </div>
        </div>
    </form>
</div>
