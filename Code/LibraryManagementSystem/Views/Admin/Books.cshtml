@{
    ViewData["Title"] = "Book Management";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .admin-page-container {
        position: absolute;
        left: 20px;
        top: 170px;
        width: calc(100% - 40px);
        height: calc(100vh - 210px);
        background: #FFFFFF;
        border-radius: 12px;
        padding: 30px;
        box-sizing: border-box;
        box-shadow: 0px 4px 10px rgba(0, 0, 0, 0.05);
        overflow: hidden;
    }

    .page-title {
        position: absolute;
        left: 20px;
        top: 103px;
        font-family: 'Montserrat';
        font-weight: 600;
        font-size: 25px;
        color: #000000;
        margin: 0;
    }

    .header-actions {
        position: absolute;
        right: 20px;
        top: 98px;
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .btn-add-book {
        width: 136px;
        height: 44px;
        background: #050000;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        color: #FFFFFF;
        text-decoration: none;
        font-family: 'Montserrat';
        font-size: 16px;
        flex-shrink: 0;
    }

    .search-container {
        width: 300px;
        height: 46px;
        background: #FFFFFF;
        border: 1px solid #E8E8E8;
        border-radius: 12px;
        display: flex;
        align-items: center;
        padding: 0 16px;
        gap: 16px;
    }

    .search-input {
        border: none;
        outline: none;
        width: 100%;
        font-family: 'Montserrat';
        font-size: 16px;
        color: #727374;
    }

    .admin-table {
        width: 100%;
        border-collapse: collapse;
        font-family: 'Montserrat';
        table-layout: fixed;
    }

    .admin-table th {
        padding: 15px 10px;
        font-weight: 500;
        font-size: 16px;
        color: #000000;
        border-bottom: 1px solid #000000;
        text-align: center;
    }

    /* Column spacing distribution for Books */
    .col-id { width: 8%; }
    .col-name { width: 30%; }
    .col-type { width: 15%; }
    .col-lang { width: 15%; }
    .col-avail { width: 17%; }
    .col-action { width: 15%; }

    .admin-table td {
        padding: 20px 10px;
        text-align: center;
        font-size: 16px;
        color: #151619;
        font-weight: 500;
    }

    .action-group {
        display: flex;
        justify-content: center;
        gap: 15px;
    }

    .action-btn {
        background: none;
        border: none;
        cursor: pointer;
        padding: 0;
    }

    .btn-confirm-popup, .btn-close-view-popup, .btn-delete-confirm-popup {
        position: absolute;
        width: 259px;
        height: 54px;
        background: #000000;
        border-radius: 10px;
        border: none;
        cursor: pointer;
        font-family: 'Montserrat';
        font-weight: 700;
        font-size: 16px;
        color: #FFFFFF;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .btn-delete-confirm-popup {
        left: 184px;
        top: 302px;
    }

    .btn-confirm-popup {
        left: 320px;
        top: 391px;
    }

    .btn-close-view-popup {
        left: 184px;
        top: 391px;
    }

    /* View Modal Details Frame */
    .view-frame-239 {
        box-sizing: border-box;
        position: absolute;
        width: 531px;
        height: 195px;
        left: 48px;
        top: 162px;
        border: 1px solid #DDDDDD;
        border-radius: 10px;
        display: flex;
    }

    .view-left-pane {
        width: 280px;
        height: 100%;
        position: relative;
        padding-left: 30px;
    }

    .view-right-pane {
        flex: 1;
        position: relative;
        padding-left: 17px;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .view-divider-v {
        position: absolute;
        width: 1px;
        height: 165px;
        background: #828282;
        left: 280px;
        top: 15px;
    }

    .view-row {
        height: 39px;
        display: flex;
        align-items: center;
        font-family: 'Montserrat';
        font-size: 12px;
        color: #000000;
        border-bottom: 1px solid #828282;
        width: 230px;
    }

    .view-row:last-child {
        border-bottom: none;
    }

    .view-label {
        font-weight: 400;
    }

    .saved-by-box {
        font-family: 'Montserrat';
        font-size: 12px;
        color: #000000;
        line-height: 1.4;
    }
</style>

<h1 class="page-title">Book Management</h1>

<div class="header-actions">
    <a href="javascript:void(0)" class="btn-add-book" onclick="openModal('add')">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 22C17.5 22 22 17.5 22 12C22 6.5 17.5 2 12 2C6.5 2 2 6.5 2 12C2 17.5 6.5 22 12 22Z" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M8 12H16" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M12 16V8" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Add Book
    </a>

    <div class="search-container">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M11 19C15.4183 19 19 15.4183 19 11C19 6.58172 15.4183 3 11 3C6.58172 3 3 6.58172 3 11C3 15.4183 6.58172 19 11 19Z" stroke="#292D32" stroke-width="1.5"/>
            <path d="M21 21L16.65 16.65" stroke="#292D32" stroke-width="1.5" stroke-opacity="0.4" stroke-linecap="round"/>
        </svg>
        <input type="text" class="search-input" placeholder="Search by ID or Type">
    </div>
</div>

<div class="admin-page-container">
    <div style="height: 100%; overflow-y: auto;">
        <table class="admin-table">
            <thead>
                <tr>
                    <th class="col-id">ID</th>
                    <th class="col-name">Name</th>
                    <th class="col-type">Type</th>
                    <th class="col-lang">Language</th>
                    <th class="col-avail">Availability</th>
                    <th class="col-action">Action</th>
                </tr>
            </thead>
            <tbody>
                @for (int i = 1; i <= 10; i++)
                {
                    <tr>
                        <td>@i</td>
                        <td style="text-align: left; padding-left: 20px;">Hibernate Core ~11th</td>
                        <td>Educational</td>
                        <td>English</td>
                        <td style="color: #000000">@(i % 3 == 0 ? "Borrowed" : "Available")</td>
                        <td>
                            <div class="action-group">
                                <!-- Edit -->
                                <button class="action-btn" style="color: #000000;" onclick="openModal('edit')">
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                        <path d="M11 4H4C3.46957 4 2.96086 4.21071 2.58579 4.58579C2.21071 4.96086 2 5.46957 2 6V20C2 20.5304 2.21071 21.0391 2.58579 21.4142C2.96086 21.7893 3.46957 22 4 22H18C18.5304 22 19.0391 21.7893 19.4142 21.4142C19.7893 21.0391 20 20.5304 20 20V13M18.5 2.5C18.8978 2.10217 19.4374 1.87868 20 1.87868C20.5626 1.87868 21.1022 2.10217 21.5 2.5C21.8978 2.89783 22.1213 3.43739 22.1213 4C22.1213 4.56261 21.8978 5.10217 21.5 5.5L12 15L8 16L9 12L18.5 2.5Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                    </svg>
                                </button>
                                <!-- Delete -->
                                <button class="action-btn" style="color: #000000;" onclick="openDeleteModal()">
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                        <path d="M3 6H21M19 6V20C19 21 18 22 17 22H7C6 22 5 21 5 20V6M8 6V4C8 3 9 2 10 2H14C15 2 16 3 16 4V6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                    </svg>
                                </button>
                                <!-- View -->
                                <button class="action-btn" style="color: #000000;" onclick="openViewModal()">
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                        <path d="M12 22C17.5228 22 22 17.5228 22 12C22 6.47715 17.5228 2 12 2C6.47715 2 2 6.47715 2 12C2 17.5228 6.47715 22 12 22Z" stroke="currentColor" stroke-width="2"/>
                                        <path d="M12 18C15.3137 18 18 15.3137 18 12C18 8.68629 15.3137 6 12 6C8.68629 6 6 8.68629 6 12C6 15.3137 8.68629 18 12 18Z" stroke="currentColor" stroke-width="2"/>
                                    </svg>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Book Modal (Add/Update) -->
<div class="modal-overlay" id="bookModal">
    <div class="add-modal-content">
        <div class="modal-header-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M4 19.5V4.5C4 3.39543 4.89543 2.5 6 2.5H18C19.1046 2.5 20 3.39543 20 4.5V19.5C20 20.6046 19.1046 21.5 18 21.5H6C4.89543 21.5 4 20.6046 4 19.5Z" stroke="black" stroke-width="2"/>
                <path d="M12 2.5V21.5" stroke="black" stroke-width="2"/>
            </svg>
        </div>
        <h2 class="modal-title" id="modalTitle">Add Book</h2>
        <button class="close-square" onclick="closeModal()">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect width="24" height="24" rx="6" fill="white"/>
                <path d="M9.17004 14.83L14.83 9.17004" stroke="#525252" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M14.83 14.83L9.17004 9.17004" stroke="#525252" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                <rect x="0.75" y="0.75" width="22.5" height="22.5" rx="5.25" stroke="#525252" stroke-width="1.5"/>
            </svg>
        </button>
        <div class="modal-line"></div>

        <!-- Name -->
        <div class="input-field-container" style="width: 441px; height: 42px; left: 93px; top: 168px;">
            <input type="text" class="modal-input" id="bookName" placeholder="Name">
        </div>

        <!-- Language -->
        <div class="input-field-container" style="width: 441px; height: 42px; left: 93px; top: 235px;">
            <input type="text" class="modal-input" id="bookLang" placeholder="Language">
        </div>

        <!-- Type -->
        <div class="input-field-container" style="width: 293px; height: 42px; left: 93px; top: 302px;">
            <input type="text" class="modal-input" id="bookType" placeholder="Type">
        </div>

        <!-- Quantity -->
        <div class="input-field-container" style="width: 133px; height: 42px; left: 401px; top: 302px;">
            <input type="number" class="modal-input" id="bookQty" placeholder="Quantity">
        </div>

        <button class="btn-cancel-popup" onclick="closeModal()">CANCEL</button>
        <button class="btn-confirm-popup" id="modalConfirmBtn">ADD</button>
    </div>
</div>

<!-- View Book Modal -->
<div class="modal-overlay" id="viewBookModal">
    <div class="add-modal-content">
        <h2 class="modal-title" style="left: 124px; top: 64px;">View Book</h2>
        <button class="close-square" onclick="closeViewModal()">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect width="24" height="24" rx="6" fill="white"/>
                <path d="M9.17004 14.83L14.83 9.17004" stroke="#525252" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M14.83 14.83L9.17004 9.17004" stroke="#525252" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                <rect x="0.75" y="0.75" width="22.5" height="22.5" rx="5.25" stroke="#525252" stroke-width="1.5"/>
            </svg>
        </button>
        <div class="modal-line"></div>

        <div class="view-frame-239">
            <div class="view-left-pane">
                <div class="view-row"><span class="view-label">Book ID : 1</span></div>
                <div class="view-row"><span class="view-label">Name : Hibernate - Core</span></div>
                <div class="view-row"><span class="view-label">Type : Educational</span></div>
                <div class="view-row" style="border-bottom: none;"><span class="view-label">Language : English</span></div>
            </div>
            <div class="view-divider-v"></div>
            <div class="view-right-pane">
                <div class="saved-by-box">
                    Saved by :<br>
                    Nisal Gunasekara<br>
                    (Admin)
                </div>
            </div>
        </div>

        <button class="btn-close-view-popup" onclick="closeViewModal()">CLOSE</button>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal-overlay" id="deleteBookModal">
    <div class="add-modal-content" style="height: 400px;">
        <div class="modal-header-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M3 6H21M19 6V20C19 21 18 22 17 22H7C6 22 5 21 5 20V6M8 6V4C8 3 9 2 10 2H14C15 2 16 3 16 4V6" stroke="black" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
        </div>
        <h2 class="modal-title" style="width: 210px;">Delete Confirmation</h2>
        <button class="close-square" onclick="closeDeleteModal()">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect width="24" height="24" rx="6" fill="white"/>
                <path d="M9.17004 14.83L14.83 9.17004" stroke="#525252" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M14.83 14.83L9.17004 9.17004" stroke="#525252" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                <rect x="0.75" y="0.75" width="22.5" height="22.5" rx="5.25" stroke="#525252" stroke-width="1.5"/>
            </svg>
        </button>
        <div class="modal-line"></div>

        <p style="position: absolute; width: 336px; left: 146px; top: 170px; font-family: 'Montserrat'; font-size: 18px; line-height: 140%; color: #000000; margin: 0;">
            Are you certain you wish to proceed with the deletion of the selected entry?
        </p>

        <button class="btn-delete-confirm-popup" onclick="closeDeleteModal()">CONFIRM</button>
    </div>
</div>

<script>
    const modal = document.getElementById('bookModal');
    const viewModal = document.getElementById('viewBookModal');
    const deleteModal = document.getElementById('deleteBookModal');
    const modalTitle = document.getElementById('modalTitle');
    const modalConfirmBtn = document.getElementById('modalConfirmBtn');

    function openModal(mode) {
        if (mode === 'add') {
            modalTitle.innerText = 'Add Book';
            modalConfirmBtn.innerText = 'ADD';
            // Clear inputs
            document.getElementById('bookName').value = '';
            document.getElementById('bookLang').value = '';
            document.getElementById('bookType').value = '';
            document.getElementById('bookQty').value = '';
        } else {
            modalTitle.innerText = 'Update Book';
            modalConfirmBtn.innerText = 'UPDATE';
            // Mock data for update
            document.getElementById('bookName').value = 'Hibernate Core ~11th';
            document.getElementById('bookLang').value = 'English';
            document.getElementById('bookType').value = 'Educational';
            document.getElementById('bookQty').value = '5';
        }
        modal.style.display = 'flex';
    }

    function openViewModal() {
        viewModal.style.display = 'flex';
    }

    function openDeleteModal() {
        deleteModal.style.display = 'flex';
    }

    function closeModal() {
        modal.style.display = 'none';
    }

    function closeViewModal() {
        viewModal.style.display = 'none';
    }

    function closeDeleteModal() {
        deleteModal.style.display = 'none';
    }

    window.onclick = function(event) {
        if (event.target == modal) {
            closeModal();
        } else if (event.target == viewModal) {
            closeViewModal();
        } else if (event.target == deleteModal) {
            closeDeleteModal();
        }
    }
</script>
