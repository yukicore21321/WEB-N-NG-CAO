@model List<LibraryManagementSystem.Models.Book>

@{
    ViewData["Title"] = "Quản lý sách";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<style>
    .modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.5);
        display: none;
        justify-content: center;
        align-items: center;
        z-index: 9999;
    }

    .add-modal-content {
        position: relative;
        width: 1020px;
        height: 630px;
        background: #F5F5F5;
        border-radius: 12px;
        padding: 40px;
        box-sizing: border-box;
    }

    .modal-header-icon {
        position: absolute;
        width: 42px;
        height: 42px;
        left: 40px;
        top: 35px;
        background: #E3E3E3;
        border-radius: 8px;

        display: flex;
        align-items: center;
        justify-content: center;
    }

    .modal-title {
        position: absolute;
        left: 95px;
        top: 42px;

        font-family: 'Montserrat';
        font-size: 24px;
        font-weight: 600;
        margin: 0;
    }

    .close-square {
        position: absolute;
        top: 42px;
        right: 40px;

        border: none;
        background: none;
        cursor: pointer;
        font-size: 18px;
    }

    .modal-line {
        position: absolute;
        left: 40px;
        top: 95px;

        width: calc(100% - 80px);
        height: 1px;
        background: #A8A8A8;
    }

    .input-field-container {
        position: absolute;
    }

    .modal-input {

        width: 100%;

        height: 100%;

        border-radius: 12px;

        background: white;

        padding: 0 18px;

        font-size: 15px;

        outline: none;

        box-sizing: border-box;

        color: black;
    }

    .btn-cancel-popup-book {
        height: 54px;
        width: 48%;
        background: #D9D9D9;

        border: none;
        border-radius: 10px;

        font-size: 16px;
        font-weight: 700;

        cursor: pointer;
    }

    .btn-confirm-popup-book {
        height: 54px;
        width: 48%;
        background: black;
        color: white;

        border: none;
        border-radius: 10px;

        font-size: 16px;
        font-weight: 700;

        cursor: pointer;
    }

    .btn-cancel-container {
        position: absolute;
        left: 100px;
        right: 100px;
        top: 550px;
        display: flex;
        justify-content: space-between;
    }

    .upload-wrapper {

        position: absolute;

        top: 180px;
        right: 93px;

        display: flex;
        gap: 20px;
    }

    .image-preview-box {

        width: 180px;
        height: 180px;

        border-radius: 16px;

        overflow: hidden;

        background: #F3F3F3;

        border: 1px solid #E1E1E1;
        text-align: center;
    }

    .image-preview-box img {

        height: 100%;
        object-fit: cover;
    }

    .upload-box {

        width: 180px;
        height: 180px;

        border: 2px dashed #B8B8B8;
        border-radius: 16px;

        background: white;

        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;

        gap: 12px;

        cursor: pointer;

        transition: 0.2s;
    }

    .upload-box:hover {

        border-color: black;

        background: #FAFAFA;
    }

    .upload-box span {

        font-size: 15px;
        font-weight: 600;

        color: #444;
    }
</style>
<div class="container-fluid mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <h2>Quản lý sách</h2>
         <div class="d-flex gap-3">

        <!-- SEARCH -->

        <form method="get"

              asp-controller="Book"

              asp-action="Index">

            <div class="d-flex gap-2">

                <input type="text"

                       name="keyword"

                       value="@ViewBag.Keyword"

                       class="form-control"

                       placeholder="Tìm tên sách"

                       style="width:320px;height:42px;" />

                <button type="submit"

                        class="btn btn-dark">

                    Tìm kiếm

                </button>

            </div>

        </form>

    </div>
        <button class="btn btn-dark" onclick="openModal()">
            Thêm sách
        </button>
        
    </div>
    
    <table class="table table-bordered table-hover align-middle">

        <thead class="table-dark">

            <tr>
                <th>ID</th>
                <th>Bìa sách</th>
                <th>Tên sách</th>
                <th>Mô tả</th>
                <th>Tác giả</th>
                <th>Số lượng</th>
                <th>Có sẵn</th>
                <th width="150">Hành động</th>
            </tr>

        </thead>

        <tbody>

            @if (Model != null && Model.Any())
            {
                @foreach (var item in Model)
                {
                    <tr>

                        <td>@item.Id</td>

                        <td>
                            <img src="@item.ImageUrl" alt="Book Cover" width="100" style="object-fit: cover;" />
                        </td>

                        <td>@item.Title</td>

                        <td>
                            @(string.IsNullOrEmpty(item.Description)
                            ? ""
                            : item.Description)
                        </td>
                        <td>@item.Author</td>
                        <td>@item.Quantity</td>
                        <td>@item.AvailableQuantity</td>
                        <td>
                            <div class="d-flex gap-2">

                                <!-- EDIT -->
                                <button class="btn btn-sm" onclick="openEditModal(
                                    @item.Id,
                                    '@item.Title',
                                    '@item.Description',
                                    '@item.Author',
                                    '@item.Publisher',
                                    @item.Quantity,
                                    @item.CategoryId,
                                    @item.PublishYear,
                                     '@item.ImageUrl'
                                    )">

                                    <img src="~/images/edit-icon.png" width="32" height="32" fill="none" alt="Close Icon"
                                         class="w-3 h-3" />


                                </button>

                                <!-- DELETE -->
                                <form asp-area="Admin" asp-controller="Book" asp-action="Delete" asp-route-id="@item.Id"
                                      method="post" onsubmit="return confirm('Bạn có chắc muốn xoá sách này?');">

                                    <button type="submit" class="btn  btn-sm">
                                        <img src="~/images/trash-icon.png" width="32" height="32" fill="none" alt="Close Icon"
                                             class="w-3 h-3" />
                                    </button>
                                </form>

                            </div>

                        </td>

                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="8" class="text-center">
                        Không có sách nào trong hệ thống.
                    </td>
                </tr>
            }

        </tbody>

    </table>

</div>

<!-- MODAL -->
<!-- Book Modal -->
<div class="modal-overlay" id="bookModal">

    <div class="add-modal-content">

        <!-- ICON -->
        <div class="modal-header-icon">
            <img src="~/images/book-icon.png" width="32" height="32" fill="none" alt="Book Icon" class="w-3 h-3" />
        </div>

        <!-- TITLE -->
        <h2 class="modal-title" id="modalTitle">
            Thêm sách
        </h2>

        <!-- CLOSE -->
        <button class="close-square" onclick="closeModalBook()">
            <img src="~/images/close-icon.png" width="32" height="32" fill="none" alt="Close Icon" class="w-3 h-3" />
        </button>

        <!-- LINE -->
        <div class="modal-line"></div>

        <!-- FORM -->
        <form id="bookForm" method="post" enctype="multipart/form-data" asp-action="Create">

            <input type="hidden" id="bookId" name="Id" />

            <div>
                <div class="input-field-container" style="
                    width: 400px;
                    height: 42px;
                    left: 93px;
                    top: 180px;
                    ">

                    <input type="text" class="modal-input" id="bookName" name="Title" placeholder="Nhập tên sách"
                           required>

                </div>

                <div class="input-field-container" style="
                    width: 400px;
                    height: 42px;
                    left: 93px;
                    top: 250px;
                    ">

                    <input type="text" class="modal-input" id="bookDescription" name="Description"
                           placeholder="Nhập thông tin mô tả" required>

                </div>
                <div class="input-field-container" style="
                    width: 400px;
                    height: 42px;
                    left: 93px;
                    top: 320px;
                    ">

                    <input type="text" class="modal-input" id="bookAuthor" name="Author" placeholder="Nhập tên tác giả"
                           required>

                </div>
                <div class="input-field-container" style="
                    width: 400px;
                    height: 42px;
                    left: 93px;
                    top: 390px;
                    ">

                    <input type="text" class="modal-input" id="bookPublisher" name="Publisher"
                           placeholder="Nhập tên nhà xuất bản" required>
                </div>

                <div class="input-field-container" style="
                    width: 400px;
                    height: 42px;
                    left: 93px;
                    top: 460px;
                    ">

                    <input type="number" class="modal-input" id="bookQuantity" name="Quantity"
                           placeholder="Nhập số lượng sách" min="0" required>
                </div>
            </div>
            <div>
                <div class="upload-wrapper">

                    <!-- IMAGE PREVIEW -->
                    <div class="image-preview-box">

                        <img id="previewImage" />

                    </div>

                    <!-- UPLOAD -->
                    <label class="upload-box">

                        <input type="file" id="imageInput" name="logoFile" accept="image/*" hidden />

                        <img src="~/images/upload-icon.png" width="40" height="40" alt="Upload Icon" />

                        <span>
                            Chọn ảnh
                        </span>

                    </label>

                </div>

               

                <div class="input-field-container" id="bookCategory" name="CategoryId" style="
                    width: 400px;
                    height: 42px;
                    right: 93px;
                    top: 390px;
                    ">
                    <select style="width:100%;border:none;outline:none;font-size:15px;color:black;border-radius:12px;"
                            id="bookCategorySelect" name="CategoryId" required>
                        <option value="">-- Chọn thể loại --</option>
                        @foreach (var tm in (List<LibraryManagementSystem.Models.Category>)ViewBag.Categories)
                        {
                            <option value="@tm.Id">@tm.Name</option>
                        }
                    </select>
                </div>

                <div class="input-field-container" style="
                    width: 400px;
                    height: 42px;
                    right: 93px;
                    top: 460px;
                    ">

                    <input type="number" class="modal-input" id="bookPublishYear" name="PublishYear"
                           placeholder="Nhập năm xuất bản" min="0" required>
                </div>
            </div>
            <!-- BUTTON -->
            <div class="btn-cancel-container">
                <button type="button" class="btn-cancel-popup-book" onclick="closeModalBook()">

                    Huỷ

                </button>

                <button type="submit" class="btn-confirm-popup-book" id="saveBtn">

                    LƯU

                </button>
            </div>
        </form>

    </div>

</div>


<script>

    const modalBook =
        document.getElementById("bookModal");
    const openModal = () => {

        document.getElementById("modalTitle").innerText =
            "Thêm sách";

        document.getElementById("bookForm").action =
            "/Admin/Book/Create"

        document.getElementById("bookId").value = "";

        document.getElementById("bookName").value = "";

        document.getElementById("bookDescription").value = "";

        modalBook.style.display = "flex";
    }

    function openEditModal(
    id,
    title,
    description,
    author,
    publisher,
    quantity,
    categoryId,
    publishYear,
    imageUrl
) {

    document.getElementById("modalTitle")
        .innerText = "Cập nhật sách";

    document.getElementById("bookForm")
        .action = "/Admin/Book/Edit";

    document.getElementById("bookId").value =
        id;

    document.getElementById("bookName").value =
        title;

    document.getElementById("bookDescription").value =
        description;

    document.getElementById("bookAuthor").value =
        author;

    document.getElementById("bookPublisher").value =
        publisher;

    document.getElementById("bookQuantity").value =
        quantity;

    document.getElementById("bookCategorySelect").value =
        categoryId;

    document.getElementById("bookPublishYear").value =
        publishYear;

    document.getElementById("previewImage").src =
        imageUrl;

    modalBook.style.display = "flex";
}

    const closeModalBook = () => {
        modalBook.style.display = "none";
    }

</script>

<script>

    const imageInput =
        document.getElementById("imageInput");

    const previewImage =
        document.getElementById("previewImage");

    imageInput.addEventListener("change", function (e) {

        const file = e.target.files[0];

        if (file) {

            previewImage.src =
                URL.createObjectURL(file);
        }
    });

</script>