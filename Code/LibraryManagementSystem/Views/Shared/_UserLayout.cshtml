@using Microsoft.AspNetCore.Identity
@using LibraryManagementSystem.Models
@inject UserManager<ApplicationUser> UserManager
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LibraryManagementSystem</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body {
            margin: 0;
            padding: 0;
            width: 1920px;
            height: 1080px;
            background: #F4F4F4;
            overflow-y: auto;
            overflow-x: hidden;
            font-family: 'Montserrat', sans-serif;
        }

        /* Frame 201 - Sidebar */
        .sidebar-container {
            position: absolute;
            width: 93px;
            height: 1080px;
            left: 0px;
            top: 0px;
            background: #000000;
            z-index: 100;
        }

        /* Sidebar Logo (Group) */
        .sidebar-logo {
            position: absolute;
            left: 22.58%;
            right: 21.08%;
            top: 2.5%;
            height: 42px; /* 1080 * (1 - 0.9356 - 0.025) = 42.5px */
            display: flex;
            align-items: center;
            justify-content: center;
        }

        /* Sidebar Buttons */
        .sidebar-btn {
            position: absolute;
            width: 93px;
            height: 48px;
            left: 0px;
            display: flex;
            align-items: center;
            justify-content: center;
            border: none;
            cursor: pointer;
            text-decoration: none;
        }

        .btn-icon {
            position: absolute;
            width: 24px;
            height: 24px;
            left: 35px;
            top: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .inactive-btn {
            background: #000000;
            color: #FFFFFF;
        }

        .active-btn {
            background: #FFFFFF;
            color: #000000;
        }

        .sidebar-btn {
            transition: all 0.2s ease;
        }

        .sidebar-btn:hover:not(.active-btn) {
            background: rgba(255, 255, 255, 0.1);
        }

        /* Page transition animation */
        @@keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        .content-animate {
            animation: fadeIn 0.3s ease-out forwards;
        }

        /* PopUp Styles */
        #credentialsPopup {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.5);
            z-index: 1000;
            align-items: center;
            justify-content: center;
        }

        .popup-content {
            position: relative;
            width: 627px;
            height: 520px;
            background: #FFFFFF;
            border-radius: 20px;
            box-shadow: 0px 10px 30px rgba(0, 0, 0, 0.2);
            overflow: hidden;
        }

        .input-frame {
            display: flex;
            flex-direction: row;
            align-items: center;
            padding: 12px 16px;
            gap: 8px;
            position: absolute;
            width: 278px;
            height: 42px;
            left: 260px;
            background: #FFFFFF;
            border: 1px solid #3D3E3E;
            border-radius: 12px;
        }

        .label-text {
            position: absolute;
            width: 155px;
            height: 18px;
            left: 84px;
            font-family: 'Montserrat';
            font-weight: 400;
            font-size: 13px;
            line-height: 140%;
            color: #3D3E3E;
        }

        .popup-btn {
            position: absolute;
            width: 259px;
            height: 54px;
            border-radius: 10px;
            border: none;
            cursor: pointer;
            font-family: 'Montserrat';
            font-weight: 700;
            font-size: 16px;
            transition: opacity 0.3s;
        }

        .dropdown-item:hover {
            background: #F5F5F5;
        }

        .dropdown-item svg {
            width: 18px;
            height: 18px;
        }

        /* Settings Dropdown */
        .settings-dropdown {
            position: absolute;
            top: 71px;
            right: 0;
            width: 200px;
            background: #FFFFFF;
            border: 1px solid #E8E8E8;
            border-top: none;
            box-shadow: 0px 8px 16px rgba(0, 0, 0, 0.1);
            display: none;
            flex-direction: column;
            z-index: 1001;
            border-bottom-left-radius: 8px;
            overflow: hidden;
        }

        .dropdown-item {
            padding: 12px 20px;
            font-size: 14px;
            font-weight: 600;
            color: #000;
            cursor: pointer;
            transition: background 0.2s;
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
            border: none;
            background: none;
            width: 100%;
            text-align: left;
        }

        /* Logout Modal Specific */
        .logout-popup-content {
            position: relative;
            width: 500px;
            height: 300px;
            background: #FFFFFF;
            border-radius: 20px;
            box-shadow: 0px 10px 30px rgba(0, 0, 0, 0.2);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 40px;
            text-align: center;
        }
    </style>
</head>
<body>
    <aside class="sidebar-container">
        <!-- Main Logo (logo.svg) -->
        <div style="position: absolute; width: 60px; height: 60px; left: 16px; top: 16px; display: flex; align-items: center; justify-content: center;">
            <a asp-controller="Home" asp-action="UserDashboard">
                <img src="~/images/logo.svg" alt="Logo" asp-append-version="true" style="width: 100%; height: auto; filter: brightness(0) invert(1);" />
            </a>
        </div>

        <!-- Dashboard Button -->
        <a asp-controller="Home" asp-action="UserDashboard" class="sidebar-btn @(ViewContext.RouteData.Values["Action"]?.ToString() == "UserDashboard" ? "active-btn" : "inactive-btn")" style="top: 158px;">
            <div class="btn-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect x="4" y="4" width="7" height="7" rx="1" fill="currentColor"/>
                    <rect x="13" y="4" width="7" height="7" rx="1" fill="currentColor"/>
                    <rect x="4" y="13" width="7" height="7" rx="1" fill="currentColor"/>
                    <rect x="13" y="13" width="7" height="7" rx="1" fill="currentColor"/>
                </svg>
            </div>
        </a>

        <!-- Borrowed/Returned Books Button (Compass Icon) -->
        <a asp-controller="Home" asp-action="BorrowedBooks" class="sidebar-btn @(ViewContext.RouteData.Values["Action"]?.ToString() == "BorrowedBooks" || ViewContext.RouteData.Values["Action"]?.ToString() == "ReturnedBooks" ? "active-btn" : "inactive-btn")" style="top: 226px;">
            <div class="btn-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M12 22C17.5228 22 22 17.5228 22 12C22 6.47715 17.5228 2 12 2C6.47715 2 2 6.47715 2 12C2 17.5228 6.47715 22 12 22Z" stroke="currentColor" stroke-width="2"/>
                    <path d="M12 15C13.6569 15 15 13.6569 15 12C15 10.3431 13.6569 9 12 9C10.3431 9 9 10.3431 9 12C9 13.6569 10.3431 15 12 15Z" fill="currentColor"/>
                    <path d="M12 7V9" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                    <path d="M12 15V17" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
            </div>
        </a>

        <!-- Catalog / Acquire Books Button (Book Icon) -->
        <a asp-controller="Books" asp-action="Index" class="sidebar-btn @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Books" ? "active-btn" : "inactive-btn")" style="top: 294px;">
            <div class="btn-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M4 19.5V4.5C4 3.39543 4.89543 2.5 6 2.5H18C19.1046 2.5 20 3.39543 20 4.5V19.5C20 20.6046 19.1046 21.5 18 21.5H6C4.89543 21.5 4 20.6046 4 19.5Z" stroke="currentColor" stroke-width="2"/>
                    <path d="M12 2.5V21.5" stroke="currentColor" stroke-width="2"/>
                </svg>
            </div>
        </a>

        <!-- User Management (User Plus Icon) -->
        @if (User.IsInRole("Admin") || User.IsInRole("Staff"))
        {
            <a asp-controller="Account" asp-action="Register" class="sidebar-btn @(ViewContext.RouteData.Values["Action"]?.ToString() == "Register" ? "active-btn" : "inactive-btn")" style="top: 362px;">
                <div class="btn-icon">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M16 21V19C16 17.9391 15.5786 16.9217 14.8284 16.1716C14.0783 15.4214 13.0609 15 12 15H5C3.93913 15 2.92172 15.4214 2.17157 16.1716C1.42143 16.9217 1 17.9391 1 19V21" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M8.5 11C10.7091 11 12.5 9.20914 12.5 7C12.5 4.79086 10.7091 3 8.5 3C6.29086 3 4.5 4.79086 4.5 7C4.5 9.20914 6.29086 11 8.5 11Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M20 8V14" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M17 11H23" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </div>
            </a>
        }


    </aside>

    <header style="position: absolute; width: calc(100% - 93px); height: 71px; left: 93px; top: 0px; background: #FFFFFF; z-index: 90; border-bottom: 1px solid #E8E8E8;">
        <!-- User Section -->
        <div style="position: absolute; width: 34px; height: 34px; left: 20px; top: 19px;">
            <svg width="34" height="34" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
                <!-- Vector 1 (Head) -->
                <rect x="29.17%" y="8.33%" width="41.66%" height="41.67%" rx="20.83%" fill="#000000"/>
                <!-- Vector 2 (Body) -->
                <path d="M12.13 60.42H87.88C87.88 60.42 85 93.75 50 93.75C15 93.75 12.13 60.42 12.13 60.42Z" fill="#000000"/>
            </svg>
        </div>
        @{
            var currentUser = await UserManager.GetUserAsync(User);
            var fullName = currentUser?.FullName ?? "User";
            var roles = await UserManager.GetRolesAsync(currentUser!);
            var roleName = roles.FirstOrDefault() ?? "Guest";

            // Translate role name
            var displayRole = roleName switch {
                "Admin" => "Quản trị viên",
                "Staff" => "Nhân viên",
                "User" => "Khách hàng",
                _ => roleName
            };
        }
        <div style="position: absolute; left: 61px; top: 16px; font-weight: 600; font-size: 16px; color: #000000;">@fullName</div>
        <div style="position: absolute; left: 61px; top: 38px; font-weight: 600; font-size: 12px; color: #000000;">@displayRole</div>

        <!-- Right Side Section -->
        <div id="clockTime" style="position: absolute; left: 1681px; top: 15px; font-weight: 700; font-size: 16px; color: #000000;">--:-- --</div>
        <div id="clockDate" style="position: absolute; left: 1669px; top: 39px; font-weight: 500; font-size: 13px; color: #000000;">--- --, ----</div>
        
        <!-- Line 16 -->
        <div style="position: absolute; width: 2px; height: 58px; left: 1764px; top: 7px; background: #000000;"></div>
        
        <!-- Settings Icon -->
        <div id="settingsIcon" style="position: absolute; width: 71px; height: 71px; right: 0; top: 0; border-left: 1px solid #E8E8E8; display: flex; align-items: center; justify-content: center; cursor: pointer;">
            <svg width="32" height="30" viewBox="0 0 32 30" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M28.6583 10.5433C25.7925 10.5433 24.6208 8.51659 26.0458 6.03076C26.8692 4.58993 26.3783 2.75326 24.9375 1.92993L22.1983 0.362427C20.9475 -0.38174 19.3325 0.0615939 18.5883 1.31243L18.4142 1.61326C16.9892 4.09909 14.6458 4.09909 13.205 1.61326L13.0308 1.31243C12.3183 0.0615939 10.7033 -0.38174 9.4525 0.362427L6.71333 1.92993C5.2725 2.75326 4.78167 4.60576 5.605 6.04659C7.04583 8.51659 5.87417 10.5433 3.00833 10.5433C1.36167 10.5433 0 11.8891 0 13.5516V16.3383C0 17.9849 1.34583 19.3466 3.00833 19.3466C5.87417 19.3466 7.04583 21.3733 5.605 23.8591C4.78167 25.2999 5.2725 27.1366 6.71333 27.9599L9.4525 29.5274C10.7033 30.2716 12.3183 29.8283 13.0625 28.5774L13.2367 28.2766C14.6617 25.7908 17.005 25.7908 18.4458 28.2766L18.62 28.5774C19.3642 29.8283 20.9792 30.2716 22.23 29.5274L24.9692 27.9599C26.41 27.1366 26.9008 25.2841 26.0775 23.8591C24.6367 21.3733 25.8083 19.3466 28.6742 19.3466C30.3208 19.3466 31.6825 18.0008 31.6825 16.3383V13.5516C31.6667 11.9049 30.3208 10.5433 28.6583 10.5433ZM15.8333 20.0908C12.9992 20.0908 10.6875 17.7791 10.6875 14.9449C10.6875 12.1108 12.9992 9.79909 15.8333 9.79909C18.6675 9.79909 20.9792 12.1108 20.9792 14.9449C20.9792 17.7791 18.6675 20.0908 15.8333 20.0908Z" fill="black"/>
            </svg>
        </div>

        <!-- Settings Dropdown -->
        <div class="settings-dropdown" id="settingsDropdown" style="top: 71px; right: 0;">
            <button class="dropdown-item" onclick="event.stopPropagation(); togglePopup(true)">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                    <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                </svg>
                Đổi mật khẩu
            </button>
            <button class="dropdown-item" onclick="event.stopPropagation(); toggleLogoutPopup(true)">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                    <polyline points="16 17 21 12 16 7"></polyline>
                    <line x1="21" y1="12" x2="9" y2="12"></line>
                </svg>
                Đăng xuất
            </button>
        </div>
    </header>

    <main style="position: absolute; left: 93px; top: 71px; width: calc(100% - 93px); height: calc(100vh - 71px); overflow: hidden;" class="content-animate">
        @RenderBody()
    </main>

    <!-- PopUp Change Credentials -->
    <div id="credentialsPopup">
        <div class="popup-content">
            <!-- Icon Frame 169 -->
            <div style="position: absolute; width: 60px; height: 60px; left: 48px; top: 48px; background: #D7D7D7; border-radius: 10px; display: flex; align-items: center; justify-content: center;">
                <svg width="32" height="30" viewBox="0 0 32 30" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M28.6583 10.5433C25.7925 10.5433 24.6208 8.51659 26.0458 6.03076C26.8692 4.58993 26.3783 2.75326 24.9375 1.92993L22.1983 0.362427C20.9475 -0.38174 19.3325 0.0615939 18.5883 1.31243L18.4142 1.61326C16.9892 4.09909 14.6458 4.09909 13.205 1.61326L13.0308 1.31243C12.3183 0.0615939 10.7033 -0.38174 9.4525 0.362427L6.71333 1.92993C5.2725 2.75326 4.78167 4.60576 5.605 6.04659C7.04583 8.51659 5.87417 10.5433 3.00833 10.5433C1.36167 10.5433 0 11.8891 0 13.5516V16.3383C0 17.9849 1.34583 19.3466 3.00833 19.3466C5.87417 19.3466 7.04583 21.3733 5.605 23.8591C4.78167 25.2999 5.2725 27.1366 6.71333 27.9599L9.4525 29.5274C10.7033 30.2716 12.3183 29.8283 13.0625 28.5774L13.2367 28.2766C14.6617 25.7908 17.005 25.7908 18.4458 28.2766L18.62 28.5774C19.3642 29.8283 20.9792 30.2716 22.23 29.5274L24.9692 27.9599C26.41 27.1366 26.9008 25.2841 26.0775 23.8591C24.6367 21.3733 25.8083 19.3466 28.6742 19.3466C30.3208 19.3466 31.6825 18.0008 31.6825 16.3383V13.5516C31.6667 11.9049 30.3208 10.5433 28.6583 10.5433ZM15.8333 20.0908C12.9992 20.0908 10.6875 17.7791 10.6875 14.9449C10.6875 12.1108 12.9992 9.79909 15.8333 9.79909C18.6675 9.79909 20.9792 12.1108 20.9792 14.9449C20.9792 17.7791 18.6675 20.0908 15.8333 20.0908Z" fill="black"/>
                </svg>
            </div>

            <div style="position: absolute; left: 124px; top: 64px; font-family: 'Montserrat'; font-weight: 600; font-size: 20px; color: #151619;">
                Change Credentials
            </div>

            <!-- Close Button -->
            <div style="position: absolute; width: 48px; height: 48px; left: 519px; top: 54px; background: #FFFFFF; border-radius: 10px; display: flex; align-items: center; justify-content: center; cursor: pointer; box-shadow: 0px 2px 10px rgba(0,0,0,0.1);" onclick="togglePopup(false)">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M18 6L6 18M6 6L18 18" stroke="#525252" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </div>

            <div style="position: absolute; width: 531px; height: 0px; left: 48px; top: 128px; border: 1px solid #E8E8E8;"></div>

            <!-- Inputs -->
            <div class="label-text" style="top: 180px;">Enter Current Password</div>
            <div class="input-frame" style="top: 167px;">
                <input type="password" placeholder="Enter Current Password" style="width: 100%; border: none; outline: none; font-family: 'Montserrat'; font-size: 13px; color: #727374;">
            </div>

            <div class="label-text" style="top: 253px;">Enter New Password</div>
            <div class="input-frame" style="top: 243px;">
                <input type="password" placeholder="Enter New Password" style="width: 100%; border: none; outline: none; font-family: 'Montserrat'; font-size: 13px; color: #727374;">
            </div>

            <div class="label-text" style="top: 326px;">Confirm New Password</div>
            <div class="input-frame" style="top: 319px;">
                <input type="password" placeholder="Confirm New Password" style="width: 100%; border: none; outline: none; font-family: 'Montserrat'; font-size: 13px; color: #727374;">
            </div>

            <!-- Buttons -->
            <button class="popup-btn" style="left: 48px; top: 412px; background: #D7D7D7; color: #000000;" onclick="togglePopup(false)">CANCEL</button>
            <button class="popup-btn" style="left: 320px; top: 412px; background: #000000; color: #FFFFFF;">CONFIRM</button>
        </div>
    </div>

    <!-- Logout Confirmation PopUp -->
    <div id="logoutPopup" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1000; align-items: center; justify-content: center;">
        <div class="logout-popup-content">
            <div style="width: 60px; height: 60px; background: #FFE5E5; border-radius: 10px; display: flex; align-items: center; justify-content: center; margin-bottom: 20px;">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#FF4D4D" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                    <polyline points="16 17 21 12 16 7"></polyline>
                    <line x1="21" y1="12" x2="9" y2="12"></line>
                </svg>
            </div>
            <h2 style="font-family: 'Montserrat'; font-weight: 600; font-size: 20px; color: #151619; margin-bottom: 10px;">Đăng xuất</h2>
            <p style="font-family: 'Montserrat'; font-size: 16px; color: #3D3E3E; margin-bottom: 30px;">Bạn có chắc chắn muốn đăng xuất không?</p>
            
            <div style="display: flex; gap: 20px; width: 100%;">
                <button onclick="toggleLogoutPopup(false)" style="flex: 1; height: 54px; background: #D7D7D7; border-radius: 10px; border: none; cursor: pointer; font-family: 'Montserrat'; font-weight: 700; font-size: 16px;">KHÔNG</button>
                <form asp-controller="Account" asp-action="Logout" method="post" style="flex: 1;">
                    <button type="submit" style="width: 100%; height: 54px; background: #FF4D4D; color: #FFFFFF; border-radius: 10px; border: none; cursor: pointer; font-family: 'Montserrat'; font-weight: 700; font-size: 16px;">CÓ</button>
                </form>
            </div>
        </div>
    </div>

    <script>
        const settingsIcon = document.getElementById('settingsIcon');
        const settingsDropdown = document.getElementById('settingsDropdown');

        settingsIcon.onclick = function(e) {
            e.stopPropagation();
            settingsDropdown.style.display = settingsDropdown.style.display === 'flex' ? 'none' : 'flex';
        }

        function togglePopup(show) {
            settingsDropdown.style.display = 'none';
            const popup = document.getElementById('credentialsPopup');
            if (popup) popup.style.display = show ? 'flex' : 'none';
        }

        function toggleLogoutPopup(show) {
            settingsDropdown.style.display = 'none';
            const popup = document.getElementById('logoutPopup');
            if (popup) popup.style.display = show ? 'flex' : 'none';
        }

        function updateClock() {
            const now = new Date();
            const timeOptions = { hour: '2-digit', minute: '2-digit', hour12: true };
            const dateOptions = { month: 'short', day: '2-digit', year: 'numeric' };
            
            const timeEl = document.getElementById('clockTime');
            const dateEl = document.getElementById('clockDate');
            if (timeEl) timeEl.textContent = now.toLocaleTimeString('en-US', timeOptions);
            if (dateEl) dateEl.textContent = now.toLocaleDateString('en-US', dateOptions);
        }
        setInterval(updateClock, 1000);
        updateClock();

        // Close on escape
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') {
                togglePopup(false);
                toggleLogoutPopup(false);
            }
        });

        window.onclick = function(event) {
            const credentialsPopup = document.getElementById('credentialsPopup');
            const logoutPopup = document.getElementById('logoutPopup');
            
            if (event.target == credentialsPopup) togglePopup(false);
            if (event.target == logoutPopup) toggleLogoutPopup(false);
            
            if (settingsDropdown && !event.target.closest('#settingsIcon') && !event.target.closest('#settingsDropdown')) {
                settingsDropdown.style.display = 'none';
            }
        }
    </script>
</body>
</html>
