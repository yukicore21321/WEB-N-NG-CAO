@using Microsoft.AspNetCore.Identity
@using LibraryManagementSystem.Models
@inject UserManager<ApplicationUser> UserManager
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BookWorm Admin</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            margin: 0;
            padding: 0;
            font-family: 'Montserrat', sans-serif;
            background: #F2F2F2;
            width: 100%;
            min-height: 100vh;
            overflow-x: hidden;
            position: relative;
        }

        /* Sidebar - Frame 201 */
        .sidebar {
            position: fixed;
            width: 222px;
            height: 100vh;
            left: 0px;
            top: 0px;
            background: #000000;
            z-index: 100;
        }

        .sidebar-logo {
            position: absolute;
            width: 142px;
            left: 40px;
            top: 33px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .nav-btn {
            position: absolute;
            width: 222px;
            height: 48px;
            left: 0px;
            display: flex;
            align-items: center;
            text-decoration: none;
            background: #000000;
            transition: all 0.2s ease;
        }

        .nav-btn.active {
            background: #FFFFFF;
        }

        .nav-icon {
            position: absolute;
            left: 40px;
            width: 24px;
            height: 24px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #FFFFFF;
        }

        .nav-btn.active .nav-icon {
            color: #000000;
        }

        .nav-btn span {
            position: absolute;
            left: 85px;
            font-weight: 600;
            font-size: 16px;
            color: #FFFFFF;
        }

        .nav-btn.active span {
            color: #000000;
        }

        /* Header - Frame 208 */
        .header {
            position: fixed;
            width: calc(100% - 222px);
            height: 71px;
            left: 222px;
            top: 0px;
            background: #FFFFFF;
            z-index: 50;
            border-bottom: 1px solid #E8E8E8;
        }

        /* Profile Section */
        .profile-avatar {
            position: absolute;
            left: 20px;
            top: 19px;
            width: 34px;
            height: 34px;
            background: #000;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .profile-name {
            position: absolute;
            left: 61px;
            top: 16px;
            font-weight: 600;
            font-size: 16px;
            color: #000;
            margin: 0;
        }

        .profile-role {
            position: absolute;
            left: 61px;
            top: 38px;
            font-weight: 600;
            font-size: 12px;
            color: #000;
            margin: 0;
        }

        /* Right Header Elements */
        .clock-container {
            position: absolute;
            right: 140px;
            top: 15px;
            text-align: right;
        }

        .clock-time {
            font-weight: 700;
            font-size: 16px;
            color: #000;
            margin: 0;
        }

        .clock-date {
            font-weight: 500;
            font-size: 13px;
            color: #000;
            margin: 0;
        }

        .header-line {
            position: absolute;
            width: 2px;
            height: 58px;
            right: 110px;
            top: 7px;
            background: #000000;
        }

        .settings-gear {
            position: absolute;
            width: 71px;
            height: 71px;
            right: 0;
            top: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            border-left: 1px solid #E8E8E8;
        }

        .main-content {
            position: absolute;
            left: 222px;
            top: 71px;
            width: calc(100% - 222px);
            height: calc(100vh - 71px);
            box-sizing: border-box;
            overflow-y: auto;
        }

        /* Modal Styles */
        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.5);
            display: none;
            justify-content: center;
            align-items: center;
            z-index: 1000;
        }

        .modal-content {
            position: relative;
            width: 627px;
            height: 514px;
            background: #FFFFFF;
            border-radius: 16px;
            box-shadow: 0px 4px 20px rgba(0, 0, 0, 0.1);
        }

        .modal-header-icon {
            position: absolute;
            width: 60px;
            height: 60px;
            left: 48px;
            top: 48px;
            background: #D7D7D7;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .modal-title {
            position: absolute;
            left: 124px;
            top: 64px;
            font-family: 'Montserrat';
            font-weight: 600;
            font-size: 20px;
            color: #151619;
            margin: 0;
        }

        .modal-line {
            position: absolute;
            width: 531px;
            height: 0px;
            left: 48px;
            top: 128px;
            border: 1px solid #000000;
        }

        .input-group {
            position: absolute;
            left: 84px;
            display: flex;
            align-items: center;
            gap: 21px;
        }

        .input-label {
            width: 155px;
            font-family: 'Montserrat';
            font-size: 13px;
            font-weight: 400;
            color: #3D3E3E;
        }

        .input-field-container {
            width: 278px;
            height: 42px;
            background: #FFFFFF;
            border: 1px solid #3D3E3E;
            border-radius: 12px;
            padding: 0 16px;
            display: flex;
            align-items: center;
            box-sizing: border-box;
        }

        .modal-input {
            width: 100%;
            border: none;
            outline: none;
            font-family: 'Montserrat';
            font-size: 13px;
            color: #727374;
        }

        .btn-cancel-popup {
            position: absolute;
            width: 259px;
            height: 54px;
            left: 48px;
            top: 412px;
            background: #D7D7D7;
            border-radius: 10px;
            border: none;
            cursor: pointer;
            font-family: 'Montserrat';
            font-weight: 700;
            font-size: 16px;
            color: #000000;
        }

        .btn-confirm-popup {
            position: absolute;
            width: 259px;
            height: 54px;
            left: 320px;
            top: 412px;
            background: #000000;
            border-radius: 10px;
            border: none;
            cursor: pointer;
            font-family: 'Montserrat';
            font-weight: 700;
            font-size: 16px;
            color: #FFFFFF;
        }
        /* Settings Dropdown */
        .settings-dropdown {
            position: absolute;
            top: 71px;
            right: 0;
            width: 200px;
            background: #FFFFFF;
            border: 1px solid #E8E8E8;
            border-top: none;
            box-shadow: 0px 8px 16px rgba(0, 0, 0, 0.1);
            display: none;
            flex-direction: column;
            z-index: 1001;
            border-bottom-left-radius: 8px;
            overflow: hidden;
        }

        .dropdown-item {
            padding: 12px 20px;
            font-size: 14px;
            font-weight: 600;
            color: #000;
            cursor: pointer;
            transition: background 0.2s;
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
            border: none;
            background: none;
            width: 100%;
            text-align: left;
        }

        .dropdown-item:hover {
            background: #F5F5F5;
        }

        .dropdown-item svg {
            width: 18px;
            height: 18px;
        }
    </style>
</head>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<body>
    <div class="sidebar">
        <div class="sidebar-logo">
            <a href="/Admin/Index">
                <img src="~/images/logo.svg" alt="Logo" style="width: 60px; height: auto; filter: brightness(0) invert(1);" />
            </a>
        </div>

        @{
            var currentController = ViewContext.RouteData.Values["Controller"]?.ToString();
            var currentAction = ViewContext.RouteData.Values["Action"]?.ToString();
        }

        <!-- Dashboard -->
        <a href="/Admin/Index" class="nav-btn @(currentController == "Admin" && currentAction == "Index" ? "active" : "")" style="top: 158px;">
            <div class="nav-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect x="4" y="4" width="7" height="7" rx="1" fill="currentColor"/>
                    <rect x="13" y="4" width="7" height="7" rx="1" fill="currentColor"/>
                    <rect x="4" y="13" width="7" height="7" rx="1" fill="currentColor"/>
                    <rect x="13" y="13" width="7" height="7" rx="1" fill="currentColor"/>
                </svg>
            </div>
            <span>Dashboard</span>
        </a>

        <!-- Catalog (Using Compass/Explore icon from User side) -->
        <a href="/Admin/Categories" class="nav-btn @(currentController == "Categories" || (currentController == "Admin" && currentAction == "Categories") ? "active" : "")" style="top: 226px;">
            <div class="nav-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="200" height="200" viewBox="0 0 24 24"><path fill="#ffffff" d="m12 2l-5.5 9h11z"/><circle cx="17.5" cy="17.5" r="4.5" fill="#ffffff"/><path fill="#ffffff" d="M3 13.5h8v8H3z"/></svg>
            </div>
            <span>Thể loại</span>
        </a>

        <!-- Books -->
        <a href="/Admin/Book" class="nav-btn @(currentController == "Book" || (currentController == "Admin" && currentAction == "Books") ? "active" : "")" style="top: 294px;">
            <div class="nav-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M4 19.5V4.5C4 3.39543 4.89543 2.5 6 2.5H18C19.1046 2.5 20 3.39543 20 4.5V19.5C20 20.6046 19.1046 21.5 18 21.5H6C4.89543 21.5 4 20.6046 4 19.5Z" stroke="currentColor" stroke-width="2"/>
                    <path d="M12 2.5V21.5" stroke="currentColor" stroke-width="2"/>
                </svg>
            </div>
            <span>Sách</span>
        </a>

        <!-- Users -->
        <a href="/Admin/Customer" class="nav-btn @(currentController == "Customer" || (currentController == "Admin" && currentAction == "Users") ? "active" : "")" style="top: 362px;">
            <div class="nav-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                    <circle cx="9" cy="7" r="4"></circle>
                    <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                    <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                </svg>
            </div>
            <span>Khách hàng</span>
        </a>

        <!-- Borrow Tickets -->
        <a href="/Admin/BorrowTicket" class="nav-btn @(currentController == "BorrowTicket" || (currentController == "Admin" && currentAction == "BorrowRecords") ? "active" : "")" style="top: 430px;">
            <div class="nav-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 10H3M21 6H3M21 14H3M21 18H3"></path>
                    <circle cx="12" cy="10" r="3"></circle>
                </svg>
            </div>
            <span>Phiếu mượn</span>
        </a>

        @if (User.IsInRole("Admin"))
            {
                <a href="/Admin/Employee" class="nav-btn @(currentController == "Employee" ? "active" : "")" style="top: 490px;">
                    <div class="nav-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="200" height="200" viewBox="0 0 20 20"><path fill="#ffffff" d="M5 5a5 5 0 0 1 10 0v2A5 5 0 0 1 5 7V5zM0 16.68A19.9 19.9 0 0 1 10 14c3.64 0 7.06.97 10 2.68V20H0v-3.32z"/></svg>
                    </div>
                    <span>Nhân viên</span>
                </a>
            }
    </div>

    <div class="header">
        <div class="profile-avatar">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                <circle cx="12" cy="7" r="4"></circle>
            </svg>
        </div>
        @{
            var currentUser = await UserManager.GetUserAsync(User);
            var fullName = currentUser?.FullName ?? "Admin User";
            var roles = currentUser != null ? await UserManager.GetRolesAsync(currentUser) : new List<string>();
            var roleName = roles.FirstOrDefault() ?? "Admin";
        }
        <p class="profile-name">@fullName</p>
        <p class="profile-role">@roleName</p>

        <div class="clock-container">
            <p class="clock-time" id="clockTime">--:-- --</p>
            <p class="clock-date" id="clockDate">--- --, ----</p>
        </div>
        
        <div class="header-line"></div>
        
        <div class="settings-gear" id="settingsGear">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="black" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="3"></circle>
                <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
            </svg>
        </div>

        <!-- Settings Dropdown -->
        <div class="settings-dropdown" id="settingsDropdown">
            <button class="dropdown-item" onclick="event.stopPropagation(); openChangePasswordModal()">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                    <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                </svg>
                Đổi mật khẩu
            </button>
            <button class="dropdown-item" onclick="event.stopPropagation(); openLogoutModal()">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                    <polyline points="16 17 21 12 16 7"></polyline>
                    <line x1="21" y1="12" x2="9" y2="12"></line>
                </svg>
                Đăng xuất
            </button>
        </div>
    </div>

    <div class="main-content">
        @RenderBody()
    </div>

    <!-- Change Credentials Modal -->
    <div class="modal-overlay" id="changeCredentialsModal">
        <div class="modal-content">
            <div class="modal-header-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M12 22C17.5228 22 22 17.5228 22 12C22 6.47715 17.5228 2 12 2C6.47715 2 2 6.47715 2 12C2 17.5228 6.47715 22 12 22Z" stroke="black" stroke-width="2"/>
                    <path d="M12 18V12" stroke="black" stroke-width="2" stroke-linecap="round"/>
                    <circle cx="12" cy="8" r="1" fill="black"/>
                </svg>
            </div>
            <h2 class="modal-title">Change Credentials</h2>
            <div class="modal-line"></div>

            <!-- Current Password -->
            <div class="input-group" style="top: 167px;">
                <span class="input-label">Current Password</span>
                <div class="input-field-container">
                    <input type="password" class="modal-input" placeholder="Enter Current Password">
                </div>
            </div>

            <!-- New Password -->
            <div class="input-group" style="top: 243px;">
                <span class="input-label">New Password</span>
                <div class="input-field-container">
                    <input type="password" class="modal-input" placeholder="Enter New Password">
                </div>
            </div>

            <!-- Confirm New Password -->
            <div class="input-group" style="top: 319px;">
                <span class="input-label">Confirm New Password</span>
                <div class="input-field-container">
                    <input type="password" class="modal-input" placeholder="Confirm New Password">
                </div>
            </div>

            <button class="btn-cancel-popup" onclick="closeModal()">CANCEL</button>
            <button class="btn-confirm-popup">CONFIRM</button>
        </div>
    </div>
    <!-- Logout Confirmation Modal -->
    <div class="modal-overlay" id="logoutConfirmModal">
        <div class="modal-content" style="height: 300px;">
            <div class="modal-header-icon" style="background: #FFE5E5;">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#FF4D4D" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                    <polyline points="16 17 21 12 16 7"></polyline>
                    <line x1="21" y1="12" x2="9" y2="12"></line>
                </svg>
            </div>
            <h2 class="modal-title">Đăng xuất</h2>
            <p style="position: absolute; left: 48px; top: 140px; font-family: 'Montserrat'; font-size: 16px; color: #3D3E3E; margin: 0;">Bạn có chắc chắn muốn đăng xuất không?</p>
            
            <button class="btn-cancel-popup" onclick="closeLogoutModal()" style="top: 210px;">KHÔNG</button>
            <form asp-controller="Account" asp-action="Logout" method="post">
                <button type="submit" class="btn-confirm-popup" style="top: 210px; background: #FF4D4D;">CÓ</button>
            </form>
        </div>
    </div>

    <script>
        const modal = document.getElementById('changeCredentialsModal');
        const logoutModal = document.getElementById('logoutConfirmModal');
        const dropdown = document.getElementById('settingsDropdown');
        const gear = document.getElementById('settingsGear');

        gear.onclick = function(e) {
            e.stopPropagation();
            dropdown.style.display = dropdown.style.display === 'flex' ? 'none' : 'flex';
        }

        function openChangePasswordModal() {
            dropdown.style.display = 'none';
            modal.style.display = 'flex';
        }

        function openLogoutModal() {
            dropdown.style.display = 'none';
            logoutModal.style.display = 'flex';
        }

        function closeModal() {
            modal.style.display = 'none';
        }

        function closeLogoutModal() {
            logoutModal.style.display = 'none';
        }

        function updateClock() {
            const now = new Date();
            const timeOptions = { hour: '2-digit', minute: '2-digit', hour12: true };
            const dateOptions = { month: 'short', day: '2-digit', year: 'numeric' };
            
            const timeEl = document.getElementById('clockTime');
            const dateEl = document.getElementById('clockDate');
            if (timeEl) timeEl.textContent = now.toLocaleTimeString('en-US', timeOptions);
            if (dateEl) dateEl.textContent = now.toLocaleDateString('en-US', dateOptions);
        }
        setInterval(updateClock, 1000);
        updateClock();

        window.onclick = function(event) {
            if (event.target == modal) {
                closeModal();
            }
            if (event.target == logoutModal) {
                closeLogoutModal();
            }
            if (dropdown && !event.target.closest('.settings-gear') && !event.target.closest('.settings-dropdown')) {
                dropdown.style.display = 'none';
            }
        }
    </script>
</body>
</html>
